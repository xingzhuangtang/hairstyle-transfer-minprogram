# ============================================
# 环境变量配置示例文件
# 复制此文件为 .env 并填入真实配置
# ============================================

# 阿里云 API 配置
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
DASHSCOPE_API_KEY=your_dashscope_api_key
BAILIAN_API_KEY=your_bailian_api_key

# OSS 配置
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name

# Flask 配置
DEBUG=false
FLASK_ENV=production
SECRET_KEY=your-random-secret-key-here
JWT_SECRET_KEY=your-random-jwt-secret-key-here

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=hairstyle_transfer

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 微信支付配置
WECHAT_MCH_ID=your_merchant_id
WECHAT_PAY_ENV=production
WECHAT_PAY_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_PAY_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_PAY_PLATFORM_CERT_PATH=/path/to/wechatpay_cert.pem
WECHAT_PAY_API_V3_KEY=your_api_v3_key_32bytes
WECHAT_NOTIFY_URL=https://your-domain.com/api/recharge/callback/wechat

# 支付宝配置（可选）
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY_FILE=/path/to/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_FILE=/path/to/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-domain.com/api/recharge/callback/alipay

# 企业微信通知配置（可选）
WECHAT_CORP_ID=your_corp_id
WECHAT_CORP_SECRET=your_corp_secret
WECHAT_AGENT_ID=your_agent_id

# 开发者测试账号配置（仅本地开发使用）
# 重要：开发者模式需要同时满足两个条件才能启用：
# 1. DEVELOPER_MODE_ENABLED=true（主开关，默认为 false）
# 2. DEVELOPER_ACCOUNTS 配置用户 ID 列表
# 未配置或 DEVELOPER_MODE_ENABLED=false 时，开发者功能默认禁用
DEVELOPER_MODE_ENABLED=false
# DEVELOPER_ACCOUNTS=5,7
