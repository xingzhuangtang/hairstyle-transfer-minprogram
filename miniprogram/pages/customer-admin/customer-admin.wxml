<!--pages/customer-admin/customer-admin.wxml-->
<view class="admin-container">
  <view class="header">
    <text class="title">{{tCaTitle}}</text>
    <text class="subtitle">{{tCaSubtitle}}</text>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-tab="0" bindtap="onTabChange"><text>{{tCaTabDashboard}}</text></view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-tab="1" bindtap="onTabChange"><text>{{tCaTabList}}</text></view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-tab="2" bindtap="onTabChange"><text>{{tCaTabSearch}}</text></view>
    <view class="tab-item {{activeTab === 3 ? 'active' : ''}}" data-tab="3" bindtap="onTabChange"><text>{{tCaTabToday}}</text></view>
  </view>

  <!-- Tab 0: 存量大盘 -->
  <scroll-view scroll-y class="tab-content" wx:if="{{activeTab === 0}}">
    <view class="loading-state" wx:if="{{loading && !dashboard}}">
      <text class="loading-text">{{tCaLoading}}</text>
    </view>
    <block wx:if="{{dashboard}}">
      <view class="card">
        <view class="card-title">{{tCaUserDist}}</view>
        <view class="stat-rows">
          <view class="stat-row"><text class="stat-label">{{tCaGuest}}</text><text class="stat-value">{{dashboard.distribution.guest}}</text><text class="stat-pct">{{dashboard.guestPct}}%</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaNormal}}</text><text class="stat-value">{{dashboard.distribution.normal}}</text><text class="stat-pct">{{dashboard.normalPct}}%</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaActiveVip}}</text><text class="stat-value highlight">{{dashboard.distribution.activeVip}}</text><text class="stat-pct">{{dashboard.activeVipPct}}%</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaExpiredVip}}</text><text class="stat-value">{{dashboard.distribution.expiredVip}}</text><text class="stat-pct">{{dashboard.expiredVipPct}}%</text></view>
        </view>
      </view>
      <view class="card">
        <view class="card-title">{{tCaAssetOverview}}</view>
        <view class="stat-rows">
          <view class="stat-row"><text class="stat-label">{{tCaTotalUsers}}</text><text class="stat-value highlight">{{dashboard.totalUsers}}</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaCirculationHairs}}</text><text class="stat-value">{{dashboard.circulationHairs}}</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaTotalRecharge}}</text><text class="stat-value money">¥{{dashboard.totalRecharge}}</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaAvgRecharge}}</text><text class="stat-value money">¥{{dashboard.avgRecharge}}</text></view>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:if="{{!dashboard && !loading}}">
      <text class="empty-icon">📊</text><text class="empty-text">{{tCaNoDashboard}}</text>
    </view>
  </scroll-view>

  <!-- Tab 1: 客户列表 -->
  <scroll-view scroll-y class="tab-content" wx:if="{{activeTab === 1}}" bindscrolltolower="onListScrollToLower">
    <view class="filter-section">
      <view class="filter-row">
        <text class="filter-label">{{tCaSortLabel}}</text>
        <picker mode="selector" range="{{sortOptions}}" value="{{sortIndex}}" bindchange="onSortChange">
          <view class="picker-value">{{sortOptions[sortIndex]}} ▼</view>
        </picker>
      </view>
      <view class="filter-row">
        <text class="filter-label">{{tCaLevelLabel}}</text>
        <picker mode="selector" range="{{levelOptions}}" value="{{levelIndex}}" bindchange="onLevelFilterChange">
          <view class="picker-value">{{levelOptions[levelIndex]}} ▼</view>
        </picker>
      </view>
    </view>
    <view class="customer-list" wx:if="{{customers.length > 0}}">
      <view class="customer-card" wx:for="{{customers}}" wx:key="id">
        <view class="customer-header">
          <text class="customer-name">{{item.displayName}}</text>
          <text class="level-tag {{item.levelClass}}">{{item.levelText}}</text>
        </view>
        <view class="customer-body">
          <view class="customer-row"><text class="customer-label">{{tCaPhone}}</text><text class="customer-value">{{item.displayPhone}}</text></view>
          <view class="customer-row"><text class="customer-label">{{tCaRechargeAmt}}</text><text class="customer-value money">¥{{item.totalRecharge}}</text></view>
          <view class="customer-row"><text class="customer-label">{{tCaHairsBalance}}</text><text class="customer-value">{{item.totalHairs}}</text></view>
          <view class="customer-row"><text class="customer-label">{{tCaLastActive}}</text><text class="customer-value">{{item.lastActiveText}}</text></view>
        </view>
      </view>
    </view>
    <view class="load-more" wx:if="{{!listNoMore && customers.length > 0}}">
      <text class="load-more-text" wx:if="{{listLoading}}">{{tCaLoading}}</text>
      <text class="load-more-text" wx:else bindtap="loadMoreCustomers">{{tCaClickLoadMore}}</text>
    </view>
    <view class="no-more" wx:if="{{listNoMore && customers.length > 0}}">
      <text class="no-more-text">{{tCaNoMore}}</text>
    </view>
    <view class="empty-state" wx:if="{{customers.length === 0 && !listLoading}}">
      <text class="empty-icon">👥</text><text class="empty-text">{{tCaNoCustomers}}</text>
    </view>
  </scroll-view>

  <!-- Tab 2: 精准查询 -->
  <scroll-view scroll-y class="tab-content" wx:if="{{activeTab === 2}}">
    <view class="search-bar">
      <input class="search-input" placeholder="{{tCaSearchPlaceholder}}" value="{{searchPhone}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" type="number" />
      <button class="search-btn" bindtap="onSearch" loading="{{searchLoading}}">{{tCaSearchBtn}}</button>
    </view>
    <view class="detail-card" wx:if="{{searchResult}}">
      <view class="detail-header">
        <text class="detail-name">{{searchResult.displayName}}</text>
        <text class="level-tag {{searchResult.member_level === 'vip' ? 'vip' : 'normal'}}">{{searchResult.levelText}}</text>
      </view>
      <view class="detail-body">
        <view class="detail-row"><text class="detail-label">{{tCaPhone}}</text><text class="detail-value">{{searchResult.displayPhone}}</text></view>
        <view class="detail-row"><text class="detail-label">{{tCaUserType}}</text><text class="detail-value">{{searchResult.typeText}}</text></view>
        <view class="detail-row"><text class="detail-label">{{tCaHairsBalance}}</text><text class="detail-value">{{searchResult.totalHairs}}</text></view>
        <view class="detail-row"><text class="detail-label">{{tCaTotalRecharge}}</text><text class="detail-value money">¥{{searchResult.totalRecharge}}</text></view>
        <view class="detail-row"><text class="detail-label">{{tCaRegisterTime}}</text><text class="detail-value">{{searchResult.createdAtText}}</text></view>
        <view class="detail-row"><text class="detail-label">{{tCaLastActive}}</text><text class="detail-value">{{searchResult.lastActiveText}}</text></view>
      </view>
      <view class="record-section" wx:if="{{searchResult.recentRecharges.length > 0}}">
        <view class="record-title">{{tCaRecentRecharges}}</view>
        <view class="record-list">
          <view class="record-item" wx:for="{{searchResult.recentRecharges}}" wx:key="index">
            <text class="record-amount money">+¥{{item.amountText}}</text>
            <text class="record-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>
      <view class="record-section" wx:if="{{searchResult.recentConsumptions.length > 0}}">
        <view class="record-title">{{tCaRecentConsumptions}}</view>
        <view class="record-list">
          <view class="record-item" wx:for="{{searchResult.recentConsumptions}}" wx:key="index">
            <text class="record-desc">{{item.service_name || item.service_type || tCaConsumption}}</text>
            <text class="record-amount">-{{item.amountText}}</text>
            <text class="record-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{searchNotFound && !searchLoading}}">
      <text class="empty-icon">🔍</text><text class="empty-text">{{tCaNotFound}}</text>
    </view>
    <view class="empty-state" wx:if="{{!searchResult && !searchNotFound && !searchLoading}}">
      <text class="empty-icon">🔍</text><text class="empty-text">{{tCaSearchHint}}</text>
    </view>
  </scroll-view>

  <!-- Tab 3: 今日动态 -->
  <scroll-view scroll-y class="tab-content" wx:if="{{activeTab === 3}}">
    <view class="loading-state" wx:if="{{loading && !todayStats}}">
      <text class="loading-text">{{tCaLoading}}</text>
    </view>
    <block wx:if="{{todayStats}}">
      <view class="card">
        <view class="card-title">{{tCaTodayNew}}</view>
        <view class="big-number">{{todayStats.newUsers}}</view>
        <view class="stat-rows" wx:if="{{todayStats.newGuests > 0 || todayStats.newRegistered > 0 || todayStats.newVip > 0}}">
          <view class="stat-row" wx:if="{{todayStats.newGuests > 0}}"><text class="stat-label">{{tCaTodayGuest}}</text><text class="stat-value">{{todayStats.newGuests}}</text></view>
          <view class="stat-row" wx:if="{{todayStats.newRegistered > 0}}"><text class="stat-label">{{tCaTodayRegistered}}</text><text class="stat-value">{{todayStats.newRegistered}}</text></view>
          <view class="stat-row" wx:if="{{todayStats.newVip > 0}}"><text class="stat-label">VIP</text><text class="stat-value highlight">{{todayStats.newVip}}</text></view>
        </view>
      </view>
      <view class="card">
        <view class="card-title">{{tCaTodayActive}}</view>
        <view class="big-number">{{todayStats.activeUsers}}</view>
      </view>
      <view class="card">
        <view class="card-title">{{tCaTodayRecharge}}</view>
        <view class="stat-rows">
          <view class="stat-row"><text class="stat-label">{{tCaRechargeAmountLabel}}</text><text class="stat-value money">¥{{todayStats.rechargeAmount}}</text></view>
          <view class="stat-row"><text class="stat-label">{{tCaRechargeCount}}</text><text class="stat-value">{{todayStats.rechargeCount}}</text></view>
        </view>
      </view>
      <view class="card">
        <view class="card-title">{{tCaTodayConsumption}}</view>
        <view class="stat-rows">
          <view class="stat-row"><text class="stat-label">{{tCaConsumptionCount}}</text><text class="stat-value">{{todayStats.consumptionCount}}{{tCaCountUnit}}</text></view>
        </view>
        <view class="stat-rows" wx:if="{{todayStats.consumptionByService.length > 0}}">
          <view class="stat-row" wx:for="{{todayStats.consumptionByService}}" wx:key="service">
            <text class="stat-label">{{item.service_name || item.service}}</text>
            <text class="stat-value">{{item.count}}{{tCaCountUnit}}</text>
          </view>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:if="{{!todayStats && !loading}}">
      <text class="empty-icon">📈</text><text class="empty-text">{{tCaNoTodayStats}}</text>
    </view>
  </scroll-view>
</view>
