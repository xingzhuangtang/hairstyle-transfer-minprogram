/* pages/customer-admin/customer-admin.wxss */

.admin-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ==================== Tab 切换栏 ==================== */

.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e8e8e8;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

/* ==================== Tab 内容区 ==================== */

.tab-content {
  height: calc(100vh - 200rpx);
}

/* ==================== 卡片样式 ==================== */

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.big-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #667eea;
  text-align: center;
  padding: 20rpx 0;
}

/* ==================== 统计行 ==================== */

.stat-rows {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  flex: 1;
}

.stat-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  min-width: 100rpx;
  text-align: right;
}

.stat-value.highlight {
  color: #667eea;
}

.stat-value.money {
  color: #ff4d4f;
}

.stat-pct {
  font-size: 24rpx;
  color: #bbb;
  min-width: 80rpx;
  text-align: right;
}

/* ==================== 筛选区 ==================== */

.filter-section {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.picker-value {
  font-size: 26rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
  background-color: #f5f7ff;
  border-radius: 8rpx;
}

/* ==================== 客户列表 ==================== */

.customer-list {
  margin: 0 30rpx;
  padding-top: 20rpx;
}

.customer-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.customer-header {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.level-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.level-tag.vip {
  background-color: #fff7e6;
  color: #fa8c16;
}

.level-tag.normal {
  background-color: #f5f5f5;
  color: #999;
}

.level-tag.guest {
  background-color: #f0f0f0;
  color: #bbb;
}

.type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background-color: #e6f7ff;
  color: #1890ff;
}

.customer-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.customer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.customer-label {
  font-size: 24rpx;
  color: #999;
}

.customer-value {
  font-size: 26rpx;
  color: #333;
}

.customer-value.money {
  color: #ff4d4f;
  font-weight: 500;
}

/* ==================== 搜索栏 ==================== */

.search-bar {
  display: flex;
  align-items: center;
  padding: 30rpx;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background-color: #ffffff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 36rpx;
  padding: 0;
  margin: 0;
  border: none;
}

.search-btn::after {
  border: none;
}

/* ==================== 详情卡片 ==================== */

.detail-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.detail-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.detail-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.detail-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
}

.detail-value.money {
  color: #ff4d4f;
  font-weight: 500;
}

/* ==================== 记录列表 ==================== */

.record-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.record-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

.record-amount {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  min-width: 100rpx;
  text-align: right;
}

.record-amount.money {
  color: #52c41a;
}

.record-time {
  font-size: 22rpx;
  color: #bbb;
  min-width: 120rpx;
  text-align: right;
  margin-left: 16rpx;
}

/* ==================== 空状态 ==================== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 加载状态 ==================== */

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 加载更多 ==================== */

.load-more {
  text-align: center;
  padding: 30rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #667eea;
}

.no-more {
  text-align: center;
  padding: 30rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}
