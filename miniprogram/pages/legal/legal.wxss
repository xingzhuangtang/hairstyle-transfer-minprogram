/* pages/legal/legal.wxss */
.legal-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.legal-header {
  padding: 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.legal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.legal-version,
.legal-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.legal-version {
  margin-bottom: 8rpx;
}

.legal-content {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.legal-text {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  line-height: 1.8;
}

/* 富文本样式 */
.legal-text h2 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #4CAF50;
}

.legal-text h2:first-child {
  margin-top: 0;
}

.legal-text p {
  font-size: 28rpx;
  color: #666;
  margin: 16rpx 0;
  text-align: justify;
}

.legal-text ul {
  margin: 16rpx 0;
  padding-left: 40rpx;
}

.legal-text li {
  font-size: 28rpx;
  color: #666;
  margin: 8rpx 0;
  text-align: justify;
}

.legal-text strong {
  font-weight: bold;
  color: #333;
}
