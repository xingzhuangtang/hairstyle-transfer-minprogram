/* pages/about/about.wxss */
.about-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  border-radius: 30rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-version {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.app-delta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 32rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.powered-by-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.powered-by {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
