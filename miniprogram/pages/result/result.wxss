/* pages/result/result.wxss */

.result-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 40rpx 30rpx;
}

/* 成功标识 */
.success-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.success-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.success-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1aad19;
}

/* 结果图片 */
.result-image-wrapper {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-image {
  width: 100%;
  min-height: 600rpx;
  border-radius: 12rpx;
}

/* 对比视图 */
.comparison-view {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.comparison-item {
  flex: 1;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.comparison-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  text-align: center;
}

.comparison-image {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background-color: #fff;
}

/* 消耗明细 */
.cost-detail {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.cost-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.cost-item.total {
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.cost-label {
  font-size: 28rpx;
  color: #666;
}

.cost-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.cost-item.total .cost-value {
  color: #667eea;
  font-size: 36rpx;
}

.divider {
  height: 1rpx;
  background-color: #f5f5f5;
  margin: 16rpx 0;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1.5;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background-color: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 8rpx;
}

/* 提示 */
.tips {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

/* 保存成功提示 */
.save-success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 60rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: scaleIn 0.3s;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
  }
  to {
    transform: scale(1);
  }
}

.check-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.modal-text {
  font-size: 32rpx;
  color: #1aad19;
  font-weight: 500;
}
