<!--pages/device/device.wxml-->
<view class="container">
  <!-- 设备列表 -->
  <view class="device-list">
    <view class="section-title">{{tDeviceMyDevices}}</view>

    <view class="device-item" wx:for="{{devices}}" wx:key="device_id">
      <view class="device-info">
        <view class="device-header">
          <image class="device-icon" src="/images/{{item.device_type === 'mobile' ? 'icons/phone' : item.device_type === 'tablet' ? 'tablet' : 'computer'}}.png" mode="aspectFit"></image>
          <view class="device-name">{{item.device_name}}</view>
          <view class="device-badge" wx:if="{{item.is_primary}}">{{tDevicePrimary}}</view>
        </view>
        <view class="device-details">
          <text class="device-id-label">{{tDeviceIdLabel}}</text>
          <text class="device-id-value">{{item.device_id}}</text>
        </view>
        <view class="device-details">
          <text class="device-bind-time">{{tDeviceBoundTime}}{{item.bound_at}}</text>
        </view>
      </view>
      <view class="device-actions" wx:if="{{devices.length > 1}}">
        <button class="unbind-btn" bindtap="unbindDevice" data-device-id="{{item.device_id}}">{{tDeviceUnbind}}</button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{devices.length === 0}}">
      <image class="empty-icon" src="/images/empty-device.png" mode="aspectFit"></image>
      <text class="empty-text" wx:if="{{!isGuest}}">{{tDeviceEmptyLoggedIn}}</text>
      <text class="empty-text" wx:else>{{tDeviceEmptyGuest}}</text>
      <button class="bind-first-btn" bindtap="goToLogin" wx:if="{{isGuest}}">{{tDeviceGoLogin}}</button>
      <button class="bind-first-btn" bindtap="bindCurrentDevice" wx:else>{{tDeviceBindCurrent}}</button>
    </view>
  </view>

  <!-- 绑定新设备按钮 -->
  <view class="bind-section" wx:if="{{devices.length < 2 && devices.length > 0}}">
    <button class="bind-new-btn" bindtap="bindCurrentDevice">{{tDeviceBindNew}}</button>
    <text class="bind-hint">{{tDeviceMaxDevicesHint}}</text>
  </view>

  <!-- 说明文字 -->
  <view class="tips-section">
    <view class="tips-title">{{tDeviceTipsTitle}}</view>
    <block wx:if="{{!isGuest}}">
      <view class="tips-item">1. {{tDeviceTip1LoggedIn}}</view>
      <view class="tips-item">2. {{tDeviceTip2LoggedIn}}</view>
      <view class="tips-item">3. {{tDeviceTip3LoggedIn}}</view>
      <view class="tips-item">4. {{tDeviceTip4LoggedIn}}</view>
    </block>
    <block wx:else>
      <view class="tips-item">1. {{tDeviceTip1Guest}}</view>
      <view class="tips-item">2. {{tDeviceTip2Guest}}</view>
      <view class="tips-item">3. {{tDeviceTip3Guest}}</view>
    </block>
  </view>
</view>
