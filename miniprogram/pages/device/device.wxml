<!--pages/device/device.wxml-->
<view class="container">
  <!-- 设备列表 -->
  <view class="device-list">
    <view class="section-title">我的设备</view>

    <view class="device-item" wx:for="{{devices}}" wx:key="device_id">
      <view class="device-info">
        <view class="device-header">
          <image class="device-icon" src="/images/{{item.device_type === 'mobile' ? 'phone' : item.device_type === 'tablet' ? 'tablet' : 'computer'}}.png" mode="aspectFit"></image>
          <view class="device-name">{{item.device_name}}</view>
          <view class="device-badge" wx:if="{{item.is_primary}}">主设备</view>
        </view>
        <view class="device-details">
          <text class="device-id-label">设备 ID：</text>
          <text class="device-id-value">{{item.device_id}}</text>
        </view>
        <view class="device-details">
          <text class="device-bind-time">绑定时间：{{item.bound_at}}</text>
        </view>
      </view>
      <view class="device-actions" wx:if="{{devices.length > 1}}">
        <button class="unbind-btn" bindtap="unbindDevice" data-device-id="{{item.device_id}}">解绑</button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{devices.length === 0}}">
      <image class="empty-icon" src="/images/empty-device.png" mode="aspectFit"></image>
      <text class="empty-text" wx:if="{{!isGuest}}">暂无绑定设备</text>
      <text class="empty-text" wx:else>登录后即可绑定设备</text>
      <button class="bind-first-btn" bindtap="goToLogin" wx:if="{{isGuest}}">去登录</button>
      <button class="bind-first-btn" bindtap="bindCurrentDevice" wx:else>绑定当前设备</button>
    </view>
  </view>

  <!-- 绑定新设备按钮 -->
  <view class="bind-section" wx:if="{{devices.length < 2 && devices.length > 0}}">
    <button class="bind-new-btn" bindtap="bindCurrentDevice">+ 绑定新设备</button>
    <text class="bind-hint">最多可绑定 2 个设备</text>
  </view>

  <!-- 说明文字 -->
  <view class="tips-section">
    <view class="tips-title">设备管理说明</view>
    <block wx:if="{{!isGuest}}">
      <view class="tips-item">1. 每个账户最多可绑定 2 个设备</view>
      <view class="tips-item">2. 设备 ID 固定不变，从游客到会员全程跟随</view>
      <view class="tips-item">3. 解绑设备后，该设备需重新绑定才能使用</view>
      <view class="tips-item">4. 至少需要保留一个已绑定设备</view>
    </block>
    <block wx:else>
      <view class="tips-item">1. 登录后即可绑定您的设备</view>
      <view class="tips-item">2. 设备 ID 固定不变，从游客到会员全程跟随</view>
      <view class="tips-item">3. 最多可绑定 2 个设备</view>
    </block>
  </view>
</view>
