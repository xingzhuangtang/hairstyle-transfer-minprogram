/* pages/chat/chat.wxss */
page {
  background-color: #f5f5f5;
}

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.message-list {
  flex: 1;
  padding: 16px;
  padding-bottom: 8px;
}

.welcome-tip {
  text-align: center;
  padding: 40px 20px;
  color: #999;
  font-size: 14px;
}

.message-item {
  margin-bottom: 16px;
  display: flex;
  flex-direction: column;
}

.user-message {
  align-items: flex-end;
}

.admin-message {
  align-items: flex-start;
}

.bubble {
  max-width: 75%;
  padding: 10px 14px;
  border-radius: 12px;
  position: relative;
  display: flex;
  align-items: flex-end;
  gap: 6px;
}

.user-message .bubble {
  background-color: #95ec69;
  border-bottom-right-radius: 4px;
}

.admin-message .bubble {
  background-color: #ffffff;
  border-bottom-left-radius: 4px;
}

.bubble-text {
  font-size: 15px;
  line-height: 1.5;
  word-break: break-word;
}

.bubble-status {
  flex-shrink: 0;
}

.status-icon {
  font-size: 12px;
  opacity: 0.6;
}

.retry-btn {
  cursor: pointer;
}

.message-time {
  font-size: 11px;
  color: #999;
  margin-top: 4px;
  padding: 0 4px;
}

.loading-more {
  text-align: center;
  padding: 10px;
  color: #999;
  font-size: 13px;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: flex-end;
  padding: 10px 12px;
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1px solid #e5e5e5;
  gap: 8px;
}

.message-input {
  flex: 1;
  padding: 10px 12px;
  font-size: 15px;
  border: 1px solid #ddd;
  border-radius: 6px;
  background-color: #f9f9f9;
  min-height: 40px;
  max-height: 100px;
}

.send-btn {
  padding: 10px 18px;
  background-color: #cccccc;
  color: #ffffff;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  transition: background-color 0.2s;
}

.send-btn.active {
  background-color: #07c160;
}

.send-btn.active:active {
  background-color: #06ad56;
}
