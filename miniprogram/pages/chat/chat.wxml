<!--pages/chat/chat.wxml-->
<view class="chat-container">
  <!-- 消息列表 -->
  <view class="message-list" scroll-y>
    <!-- 欢迎提示 -->
    <view class="welcome-tip" wx:if="{{messages.length === 0 && !loading}}">
      <text>您好！有什么可以帮助您的？</text>
    </view>

    <!-- 消息气泡 -->
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.id}}"
      class="message-item {{item.sender_type === 'user' ? 'user-message' : 'admin-message'}}"
    >
      <view class="bubble {{item.status || 'sent'}}">
        <text class="bubble-text">{{item.content}}</text>
        <view class="bubble-status" wx:if="{{item.sender_type === 'user'}}">
          <text wx:if="{{item.status === 'sending'}}" class="status-icon">⏳</text>
          <text wx:if="{{item.status === 'failed'}}" class="status-icon retry-btn" bindtap="onRetrySend" data-index="{{index}}">❌</text>
          <text wx:if="{{item.status === 'sent'}}" class="status-icon">✓</text>
        </view>
      </view>
      <view class="message-time">{{item.timeText}}</view>
    </view>

    <!-- 加载更多提示 -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <textarea
      class="message-input"
      value="{{inputValue}}"
      bindinput="onInputChange"
      placeholder="输入消息..."
      maxlength="500"
      auto-height
      confirm-type="send"
      bindconfirm="onSendMessage"
    />
    <view
      class="send-btn {{inputValue ? 'active' : ''}}"
      bindtap="onSendMessage"
    >
      <text>发送</text>
    </view>
  </view>
</view>
