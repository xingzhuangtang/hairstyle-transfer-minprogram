<!--pages/referral/referral.wxml-->
<view class="container">
  <!-- 我的惊喜标题 -->
  <view class="section-title">{{tReferralTitle}}</view>

  <!-- 彩色提示文字 -->
  <view class="tip-text">
    {{tReferralTipText}}
  </view>

  <!-- 推广二维码卡片 -->
  <view class="card qrcode-card">
    <view class="card-title">{{tReferralQrcodeCardTitle}}</view>
    <view wx:if="{{qrcodeUrl}}" class="qrcode-container">
      <image class="qrcode" src="{{qrcodeUrl}}" mode="aspectFit" bindtap="previewQrcode" />
    </view>
    <view wx:else class="qrcode-placeholder" bindtap="loadQrcode">
      <text class="placeholder-text">{{tReferralLoadQrcodeHint}}</text>
    </view>
    <view class="qrcode-actions">
      <button class="btn btn-primary" bindtap="downloadQrcode" wx:if="{{qrcodeUrl}}">{{tReferralSaveQrcode}}</button>
      <button class="btn btn-outline" open-type="share" wx:if="{{qrcodeUrl}}">{{tReferralShareToFriend}}</button>
    </view>
  </view>

  <!-- 存钱罐卡片 -->
  <view class="card piggy-card">
    <view class="piggy-header">
      <text class="piggy-label">{{tReferralPiggyBank}}</text>
      <text class="piggy-balance">{{tReferralYuan}}{{balance}}</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
      <text class="progress-text">{{tReferralYuan}}{{balance}} / {{tReferralYuan}}10</text>
    </view>
    <view class="piggy-stats">
      <text>{{tReferralTotalEarnings}}{{tReferralYuan}}{{totalEarnings}}</text>
      <text>{{tReferralReferralCount}}{{referralCount}}{{tReferralPeople}}</text>
    </view>
  </view>

  <!-- 本地消费 -->
  <view class="card feature-card" bindtap="goConsumeCash">
    <view class="feature-header">
      <view class="feature-left">
        <text class="feature-icon">💰</text>
        <text class="feature-title">{{tReferralLocalConsumption}}</text>
      </view>
      <view class="feature-status {{localUnlocked ? 'unlocked' : 'locked'}}">
        <text>{{localUnlocked ? tReferralUnlocked : tReferralLocked}}</text>
      </view>
    </view>
    <view class="progress-bar {{localUnlocked ? 'active' : ''}}">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="feature-desc">{{tReferralUseBalanceDesc}}</text>
  </view>

  <!-- 提成现金 -->
  <view class="card feature-card" bindtap="goWithdraw">
    <view class="feature-header">
      <view class="feature-left">
        <text class="feature-icon"></text>
        <text class="feature-title">{{tReferralCashWithdraw}}</text>
      </view>
      <view class="feature-status {{cashUnlocked ? 'unlocked' : 'locked'}}">
        <text>{{cashUnlocked ? tReferralUnlocked : tReferralLocked}}</text>
      </view>
    </view>
    <view class="progress-bar {{cashUnlocked ? 'active' : ''}}">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="feature-desc">{{tReferralWithdrawDesc}}</text>
  </view>

  <!-- 佣金明细 -->
  <view class="card commission-card">
    <view class="card-title">{{tReferralCommissionDetail}}</view>
    <view wx:if="{{commissionHistory.length > 0}}" class="commission-list">
      <view class="commission-item" wx:for="{{commissionHistory}}" wx:key="index">
        <view class="commission-left">
          <text class="commission-amount">+{{tReferralYuan}}{{item.amount}}</text>
          <text class="commission-reason">{{item.reason}}</text>
          <text class="commission-time">{{item.formattedTime}}</text>
        </view>
        <view class="commission-right">
          <text class="commission-nickname">{{item.refereeNickname}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-commission">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{tReferralEmptyCommission}}</text>
      <text class="empty-hint">{{tReferralEmptyCommissionHint}}</text>
    </view>
  </view>

  <!-- 本地消费弹窗 -->
  <view wx:if="{{showConsumeModal}}" class="modal-overlay" bindtap="closeConsumeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">{{tReferralConsumeModalTitle}}</view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">{{tReferralConsumeAmountLabel}}</text>
          <input class="input" type="digit" placeholder="{{tReferralConsumeAmountPlaceholder}}" value="{{consumeAmount}}" bindinput="onConsumeInput" />
        </view>
        <view class="exchange-info">{{tReferralExchangeRate}}</view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-cancel" bindtap="closeConsumeModal">{{tCommonCancel}}</button>
        <button class="btn btn-confirm" bindtap="confirmConsume" loading="{{consumeLoading}}">{{tReferralConfirmPurchase}}</button>
      </view>
    </view>
  </view>

  <!-- 提现弹窗 -->
  <view wx:if="{{showWithdrawModal}}" class="modal-overlay" bindtap="closeWithdrawModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">{{tReferralWithdrawModalTitle}}</view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">{{tReferralWithdrawAmountLabel}}</text>
          <input class="input" type="digit" placeholder="{{tReferralWithdrawAmountPlaceholder}}" value="{{withdrawAmount}}" bindinput="onWithdrawInput" />
        </view>
        <view class="withdraw-info">{{tReferralWithdrawInfo}}</view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-cancel" bindtap="closeWithdrawModal">{{tCommonCancel}}</button>
        <button class="btn btn-confirm" bindtap="confirmWithdraw" loading="{{withdrawLoading}}">{{tReferralConfirmWithdraw}}</button>
      </view>
    </view>
  </view>
</view>
