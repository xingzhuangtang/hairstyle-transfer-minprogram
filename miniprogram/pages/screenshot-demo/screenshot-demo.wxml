<!--pages/screenshot-demo/screenshot-demo.wxml-->
<view class="demo-container">
  <!-- 页面1: 首页 -->
  <view class="page-section">
    <text class="section-title">1. 首页 - 发型迁移</text>
    <view class="demo-box home">
      <view class="balance-card">
        <text class="balance-text">💰 余额: 1,234发丝</text>
        <text class="vip-badge">👑 会员50%优惠</text>
      </view>
      <view class="upload-area">
        <text class="upload-text">📸 上传发型参考图</text>
        <text class="upload-text">👤 上传客户照片</text>
      </view>
      <view class="params">
        <text>🎛️ 模型版本: v1脸型适配</text>
        <text>🎚️ 融合度: 70%</text>
      </view>
      <button class="action-btn">✨ 一键处理 (88发丝)</button>
    </view>
  </view>

  <!-- 页面2: 服务页/结果页 -->
  <view class="page-section">
    <text class="section-title">2. 服务页 - 发型迁移结果</text>
    <view class="demo-box result">
      <view class="success-header">✅ 处理成功</view>
      <view class="result-image-placeholder">
        <text class="placeholder-text">🖼️ 迁移结果图</text>
        <text class="placeholder-subtext">(此处显示发型迁移后的图片)</text>
      </view>
      <view class="cost-detail">
        <text>梳子槽: -2发丝</text>
        <text>剪刀槽: -2发丝</text>
        <text class="total">剩余: 1,810发丝</text>
      </view>
      <view class="actions">
        <button class="btn-secondary">💾 保存相册</button>
        <button class="btn-primary">🏠 返回首页</button>
      </view>
    </view>
  </view>

  <!-- 页面3: 支付页 -->
  <view class="page-section">
    <text class="section-title">3. 支付页 - 充值中心</text>
    <view class="demo-box payment">
      <view class="balance-display">
        <text class="balance-title">💰 我的余额</text>
        <text class="balance-value">剪刀: 1,234  梳子: 588</text>
      </view>

      <text class="subsection-title">选择支付方式</text>
      <view class="payment-methods">
        <view class="method-item active">
          <text class="method-icon">💚</text>
          <text class="method-name">微信支付</text>
          <text class="method-check">✓</text>
        </view>
        <view class="method-item">
          <text class="method-icon">💙</text>
          <text class="method-name">支付宝</text>
          <text class="method-check">○</text>
        </view>
      </view>

      <text class="subsection-title">选择充值金额</text>
      <view class="recharge-options">
        <view class="recharge-item">¥10 → 1000发丝</view>
        <view class="recharge-item recommended">¥20 → 2088发丝 ⭐推荐</view>
        <view class="recharge-item">¥50 → 5588发丝</view>
        <view class="recharge-item">¥100 → 11688发丝</view>
      </view>

      <button class="pay-btn">💳 立即支付 ¥20</button>
    </view>
  </view>

  <!-- 说明 -->
  <view class="instructions">
    <text class="instruction-title">📸 截图说明</text>
    <text class="instruction-item">1. 本页面包含了支付宝审核需要的所有页面样式</text>
    <text class="instruction-item">2. 每个区域对应一个需要截图的页面</text>
    <text class="instruction-item">3. 使用截图工具分别截取三个区域</text>
    <text class="instruction-item">4. 或者直接在微信开发者工具中浏览真实页面并截图</text>
  </view>
</view>
