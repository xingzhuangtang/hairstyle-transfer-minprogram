/* pages/screenshot-demo/screenshot-demo.wxss */

.demo-container {
  padding: 30rpx;
  background-color: #f8f8f8;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 40rpx 0 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
}

.demo-box {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 首页样式 */
.home .balance-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.vip-badge {
  background-color: #ffd700;
  color: #333;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.upload-area {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  padding: 40rpx;
  background-color: #ffffff;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
}

.params {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.params text {
  font-size: 26rpx;
  color: #333;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 结果页样式 */
.result .success-header {
  text-align: center;
  font-size: 36rpx;
  color: #1aad19;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.result-image-placeholder {
  background-color: #f0f0f0;
  border-radius: 12rpx;
  padding: 80rpx 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed #ddd;
}

.placeholder-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.placeholder-subtext {
  font-size: 24rpx;
  color: #999;
}

.cost-detail {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.cost-detail text {
  font-size: 28rpx;
  color: #333;
}

.cost-detail .total {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6600;
  padding-top: 15rpx;
  border-top: 1rpx solid #ddd;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  background-color: #f8f8f8;
  color: #333;
  border: 2rpx solid #ddd;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

/* 支付页样式 */
.payment .balance-display {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.balance-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.balance-value {
  display: block;
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.subsection-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin: 30rpx 0 15rpx;
  font-weight: 500;
}

.payment-methods {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.method-item {
  flex: 1;
  background-color: #f8f8f8;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.method-item.active {
  background-color: #f0f9ff;
  border-color: #1890ff;
}

.method-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.method-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.method-item.active .method-check {
  background-color: #1890ff;
  border-color: #1890ff;
  color: #ffffff;
}

.recharge-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.recharge-item {
  flex: 1;
  min-width: 300rpx;
  background-color: #f8f8f8;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 25rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.recharge-item.recommended {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  position: relative;
}

.pay-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

/* 说明 */
.instructions {
  background-color: #fff9e6;
  border-radius: 12rpx;
  padding: 30rpx;
  border: 2rpx solid #ffd700;
}

.instruction-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.instruction-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 10rpx;
}
