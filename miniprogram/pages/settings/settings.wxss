/* pages/settings/settings.wxss */
.settings-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.settings-section {
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fafafa;
  border-bottom: 1rpx solid #eee;
}

.setting-item {
  padding: 30rpx;
  display: flex;
  align-items: center;
}

/* 头像选择项 */
.avatar-item {
  justify-content: space-between;
}

.item-left {
  display: flex;
  align-items: center;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid #eee;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-text {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 昵称输入框 */
.nickname-input {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  padding: 10rpx 0;
}

.nickname-input::placeholder {
  color: #ccc;
}

/* 用户ID（只读） */
.user-id-item {
  padding: 24rpx 30rpx;
}

.user-id-text {
  font-size: 26rpx;
  color: #333;
  font-family: 'Courier New', monospace;
  word-break: break-all;
  line-height: 1.6;
  user-select: text;
}

/* 手机号显示项 */
.phone-item {
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.phone-display {
  font-size: 28rpx;
  color: #333;
}

.phone-action-text {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 16rpx;
}

/* 修改手机号弹窗 */
.change-phone-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.change-phone-modal .modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.change-phone-modal .modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
}

.change-phone-modal .modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.change-phone-modal .modal-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.change-phone-modal .input-group {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.change-phone-modal .input-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.change-phone-modal .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.change-phone-modal .code-input {
  flex: 1;
  margin-right: 20rpx;
}

.change-phone-modal .code-btn {
  padding: 12rpx 24rpx;
  background-color: #667eea;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
  line-height: 1.5;
  min-width: 160rpx;
}

.change-phone-modal .code-btn::after {
  border: none;
}

.change-phone-modal .code-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

.change-phone-modal .modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.change-phone-modal .modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.change-phone-modal .modal-btn.cancel {
  background-color: #f8f8f8;
  color: #666;
}

.change-phone-modal .modal-btn.cancel::after {
  border: none;
}

.change-phone-modal .modal-btn.confirm {
  background-color: #667eea;
  color: #ffffff;
}

.change-phone-modal .modal-btn.confirm::after {
  border: none;
}

/* 语言设置项 */
.language-item {
  justify-content: space-between;
}

.language-icon-text {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.language-item .picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #667eea;
}

.language-item .arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

/* 保存按钮区域 */
.save-section {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[loading] {
  opacity: 0.8;
}

/* 提示信息 */
.tip-section {
  margin-top: 40rpx;
  padding: 0 30rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
