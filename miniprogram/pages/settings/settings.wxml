<!--pages/settings/settings.wxml-->
<view class="settings-container">
  <!-- 头像设置 -->
  <view class="settings-section">
    <view class="section-title">头像</view>
    <view class="setting-item avatar-item" bindtap="chooseAvatar">
      <view class="item-left">
        <image class="avatar-preview" src="{{avatarUrl || '/images/icons/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="item-right">
        <text class="item-text">点击更换</text>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>
  </view>

  <!-- 昵称设置 -->
  <view class="settings-section">
    <view class="section-title">昵称</view>
    <view class="setting-item">
      <input
        class="nickname-input"
        type="text"
        placeholder="请输入昵称（最多 20 个字符）"
        value="{{nickname}}"
        maxlength="20"
        bindinput="onNicknameInput"
      />
    </view>
  </view>

  <!-- 手机号设置 -->
  <view class="settings-section">
    <view class="section-title">手机号</view>
    <view class="setting-item phone-item" bindtap="onChangePhone">
      <view class="item-left">
        <image class="item-icon" src="/images/icons/phone.png"></image>
        <text class="phone-display">{{phone || '未绑定'}}</text>
      </view>
      <view class="item-right">
        <text class="phone-action-text">修改</text>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>
  </view>

  <!-- 用户ID（只读，不可修改） -->
  <view class="settings-section">
    <view class="section-title">用户ID</view>
    <view class="setting-item user-id-item">
      <text class="user-id-text">{{userId || '未知'}}</text>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button class="save-btn" bindtap="saveSettings" loading="{{saving}}">保存</button>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <text class="tip-text">昵称修改后，其他用户可以看到您的新昵称</text>
  </view>

  <!-- 修改手机号弹窗 -->
  <view class="change-phone-modal" wx:if="{{showChangePhoneModal}}">
    <view class="modal-mask" bindtap="onCloseChangePhoneModal"></view>
    <view class="modal-content">
      <view class="modal-title">修改手机号</view>
      <view class="modal-desc">请输入新手机号并验证</view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/phone.png"></image>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{changePhone}}"
          bindinput="onChangePhoneInput" />
      </view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/code.png"></image>
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{changeCode}}"
          bindinput="onChangeCodeInput" />
        <button
          class="code-btn"
          bindtap="sendChangeCode"
          disabled="{{changeCounting}}">
          {{changeCounting ? changeCountDown + 's' : '获取验证码'}}
        </button>
      </view>
      <view class="modal-buttons">
        <button class="modal-btn cancel" bindtap="onCloseChangePhoneModal">取消</button>
        <button class="modal-btn confirm" bindtap="confirmChangePhone" loading="{{changeLoading}}">确认</button>
      </view>
    </view>
  </view>
</view>
