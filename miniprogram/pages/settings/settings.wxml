<!--pages/settings/settings.wxml-->
<view class="settings-container">
  <!-- 头像设置 -->
  <view class="settings-section">
    <view class="section-title">{{tSettingsAvatar}}</view>
    <view class="setting-item avatar-item" bindtap="chooseAvatar">
      <view class="item-left">
        <image class="avatar-preview" src="{{avatarUrl || '/images/icons/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="item-right">
        <text class="item-text">{{tSettingsClickChange}}</text>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>
  </view>

  <!-- 昵称设置 -->
  <view class="settings-section">
    <view class="section-title">{{tSettingsNickname}}</view>
    <view class="setting-item">
      <input
        class="nickname-input"
        type="text"
        placeholder="{{tSettingsNicknamePlaceholder}}"
        value="{{nickname}}"
        maxlength="20"
        bindinput="onNicknameInput"
      />
    </view>
  </view>

  <!-- 手机号设置 -->
  <view class="settings-section">
    <view class="section-title">{{tSettingsPhone}}</view>
    <view class="setting-item phone-item" bindtap="onChangePhone">
      <view class="item-left">
        <image class="item-icon" src="/images/icons/phone.png"></image>
        <text class="phone-display">{{phone || tSettingsNotBound}}</text>
      </view>
      <view class="item-right">
        <text class="phone-action-text">{{tSettingsChange}}</text>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>
  </view>

  <!-- 用户ID（只读，不可修改） -->
  <view class="settings-section">
    <view class="section-title">{{tSettingsUserId}}</view>
    <view class="setting-item user-id-item">
      <text class="user-id-text">{{userId || tSettingsUnknown}}</text>
    </view>
  </view>

  <!-- 语言设置 -->
  <view class="settings-section">
    <view class="section-title">{{tSettingsLanguage}}</view>
    <view class="setting-item language-item">
      <view class="item-left">
        <text class="language-icon-text">🌐</text>
        <text class="item-text">{{currentLocaleName}}</text>
      </view>
      <view class="item-right">
        <picker mode="selector" range="{{localeOptions}}" range-key="label" value="{{localeIndex}}" bindchange="onLocaleChange">
          <view class="picker">
            {{localeOptions[localeIndex].label}}
            <image class="arrow" src="/images/icons/arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button class="save-btn" bindtap="saveSettings" loading="{{saving}}">{{tCommonSave}}</button>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <text class="tip-text">{{tSettingsProfileTip}}</text>
  </view>

  <!-- 修改手机号弹窗 -->
  <view class="change-phone-modal" wx:if="{{showChangePhoneModal}}">
    <view class="modal-mask" bindtap="onCloseChangePhoneModal"></view>
    <view class="modal-content">
      <view class="modal-title">{{tSettingsChangePhone}}</view>
      <view class="modal-desc">{{tSettingsChangePhoneDesc}}</view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/phone.png"></image>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="{{tSettingsPhonePlaceholder}}"
          value="{{changePhone}}"
          bindinput="onChangePhoneInput" />
      </view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/code.png"></image>
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="{{tSettingsCodePlaceholder}}"
          value="{{changeCode}}"
          bindinput="onChangeCodeInput" />
        <button
          class="code-btn"
          bindtap="sendChangeCode"
          disabled="{{changeCounting}}">
          {{changeCounting ? changeCountDown + 's' : tSettingsGetCode}}
        </button>
      </view>
      <view class="modal-buttons">
        <button class="modal-btn cancel" bindtap="onCloseChangePhoneModal">{{tCommonCancel}}</button>
        <button class="modal-btn confirm" bindtap="confirmChangePhone" loading="{{changeLoading}}">{{tCommonConfirm}}</button>
      </view>
    </view>
  </view>
</view>
