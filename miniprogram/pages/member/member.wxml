<!--pages/member/member.wxml-->
<view class="member-container">
  <!-- 头部信息 -->
  <view class="member-header">
    <view class="user-info">
      <view class="avatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else>{{userInfo.nickName || tMemberUser}}</text>
      </view>
      <view class="user-details">
        <text class="nickname">{{userInfo.nickName || tMemberWechatUser}}</text>
        <view class="member-badge {{isVip ? 'vip' : 'normal'}}">
          {{isVip ? tMemberCompanionVip : tMemberNormalBadge}}
        </view>
      </view>
    </view>

    <!-- 会员状态 -->
    <view class="member-status" wx:if="{{isVip}}">
      <view class="status-item">
        <text class="label">{{tMemberDaysLeft}}</text>
        <text class="value">{{remainingDays}}{{tMemberDaysUnit}}</text>
      </view>
      <view class="status-item">
        <text class="label">{{tMemberExpireTime}}</text>
        <text class="value">{{expireCountdownText}}</text>
      </view>
    </view>
  </view>

  <!-- 会员特权 -->
  <view class="privileges-section">
    <view class="section-title">{{tMemberPrivileges}}</view>
    <view class="privileges-list">
      <view class="privilege-item">
        <view class="privilege-icon">5</view>
        <view class="privilege-info">
          <text class="privilege-title">{{tMemberPriv50off}}</text>
          <text class="privilege-desc">{{tMemberPriv50desc}}</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">45</view>
        <view class="privilege-info">
          <text class="privilege-title">{{tMemberPriv45days}}</text>
          <text class="privilege-desc">{{tMemberPriv45desc}}</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">{{tMemberPrivGiftIcon}}</view>
        <view class="privilege-info">
          <text class="privilege-title">{{tMemberPrivGift}}</text>
          <text class="privilege-desc">{{tMemberPrivGiftDesc}}</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">{{tMemberPrivBonusIcon}}</view>
        <view class="privilege-info">
          <text class="privilege-title">{{tMemberPrivBonus}}</text>
          <text class="privilege-desc">{{tMemberPrivBonusDesc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 购买会员 -->
  <view class="purchase-section" wx:if="{{!isVip}}">
    <view class="section-title">{{tMemberOpenMember}}</view>
    <view class="purchase-card">
      <view class="price">
        <text class="currency">¥</text>
        <text class="amount">99</text>
        <text class="period">{{tMemberPriceUnit}}</text>
      </view>
      <view class="purchase-tips">
        <text>{{tMemberBuyTip1}}</text>
        <text>{{tMemberBuyTip2}}</text>
        <text>{{tMemberBuyTip3}}</text>
      </view>
      <button class="purchase-btn" bindtap="buyMember">
        <text class="btn-text">{{tMemberVirtualPayOpen}}</text>
      </button>
      <text class="pay-hint">{{tMemberVirtualPayHint}}</text>
    </view>
  </view>

  <!-- 会员订单 -->
  <view class="orders-section" wx:if="{{isVip || orders.length > 0}}">
    <view class="section-title">{{tMemberOrders}}</view>
    <view class="orders-list">
      <view wx:if="{{orders.length === 0}}" class="empty orders">{{tMemberNoOrders}}</view>
      <view wx:for="{{orders}}" wx:key="id" class="order-item">
        <view class="order-header">
          <text class="order-no">{{tMemberOrderNo}}{{item.order_no}}</text>
          <text class="order-status {{item.payment_status}}">{{item.payment_status_text}}</text>
        </view>
        <view class="order-body">
          <text class="order-amount">¥{{item.amount}}</text>
          <text class="order-bonus">{{item.bonusText}}</text>
        </view>
        <view class="order-footer">
          <text class="order-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 续费提示 -->
  <view class="renew-section" wx:if="{{isVip && remainingDays <= 30}}">
    <view class="renewcard">
      <text class="renew-tip">{{tMemberRenewTip}}</text>
      <button class="renew-btn" bindtap="renewMember">
        <text class="btn-text">{{tMemberVirtualPayRenew}}</text>
      </button>
      <text class="pay-hint">{{tMemberVirtualPayRenewHint}}</text>
    </view>
  </view>
</view>
