<!--pages/member/member.wxml-->
<view class="member-container">
  <!-- 头部信息 -->
  <view class="member-header">
    <view class="user-info">
      <view class="avatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else>{{userInfo.nickName || '用户'}}</text>
      </view>
      <view class="user-details">
        <text class="nickname">{{userInfo.nickName || '微信用户'}}</text>
        <view class="member-badge {{isVip ? 'vip' : 'normal'}}">
          {{isVip ? '陪跑会员' : '普通用户'}}
        </view>
      </view>
    </view>

    <!-- 会员状态 -->
    <view class="member-status" wx:if="{{isVip}}">
      <view class="status-item">
        <text class="label">剩余天数</text>
        <text class="value">{{remainingDays}}天</text>
      </view>
      <view class="status-item">
        <text class="label">到期时间</text>
        <text class="value">{{expireAt}}</text>
      </view>
    </view>
  </view>

  <!-- 会员特权 -->
  <view class="privileges-section">
    <view class="section-title">会员特权</view>
    <view class="privileges-list">
      <view class="privilege-item">
        <view class="privilege-icon">5</view>
        <view class="privilege-info">
          <text class="privilege-title">服务 5 折优惠</text>
          <text class="privilege-desc">发型迁移、素描转换等服务享半价</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">45</view>
        <view class="privilege-info">
          <text class="privilege-title">历史记录保留 45 天</text>
          <text class="privilege-desc">操作记录长期保存，随时查看</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">赠</view>
        <view class="privilege-info">
          <text class="privilege-title">购买即赠 1000 发丝</text>
          <text class="privilege-desc">购买会员即赠送 1000 根梳子发丝</text>
        </view>
      </view>
      <view class="privilege-item">
        <view class="privilege-icon">充</view>
        <view class="privilege-info">
          <text class="privilege-title">充值额外赠送</text>
          <text class="privilege-desc">充值时获得额外梳子发丝奖励</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 购买会员 -->
  <view class="purchase-section" wx:if="{{!isVip}}">
    <view class="section-title">开通会员</view>
    <view class="purchase-card">
      <view class="price">
        <text class="currency">¥</text>
        <text class="amount">99</text>
        <text class="period">/年</text>
      </view>
      <view class="purchase-tips">
        <text>✓ 购买即赠 1000 发丝</text>
        <text>✓ 服务 5 折优惠</text>
        <text>✓ 历史记录保留 45 天</text>
      </view>
      <button class="purchase-btn" bindtap="buyMember">立即开通</button>
    </view>
  </view>

  <!-- 会员订单 -->
  <view class="orders-section" wx:if="{{isVip || orders.length > 0}}">
    <view class="section-title">会员订单</view>
    <view class="orders-list">
      <view wx:if="{{orders.length === 0}}" class="empty-orders">暂无订单记录</view>
      <view wx:for="{{orders}}" wx:key="id" class="order-item">
        <view class="order-header">
          <text class="order-no">订单号：{{item.order_no}}</text>
          <text class="order-status {{item.payment_status}}">{{item.payment_status_text}}</text>
        </view>
        <view class="order-body">
          <text class="order-amount">¥{{item.amount}}</text>
          <text class="order-bonus">赠送 {{item.bonus_hairs}} 发丝</text>
        </view>
        <view class="order-footer">
          <text class="order-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 续费提示 -->
  <view class="renew-section" wx:if="{{isVip && remainingDays <= 30}}">
    <view class="renew-card">
      <text class="renew-tip">会员即将到期，及时续费继续享受特权</text>
      <button class="renew-btn" bindtap="renewMember">立即续费</button>
    </view>
  </view>
</view>
