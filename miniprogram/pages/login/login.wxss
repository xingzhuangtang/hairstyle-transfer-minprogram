/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 100rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 240rpx;
  height: 240rpx;
  border-radius: 48rpx;
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录方式 */
.login-methods {
  width: 100%;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 30rpx;
}

.wechat-btn {
  background-color: #1aad19;
  color: #ffffff;
}

.wechat-btn::after {
  border: none;
}

.wechat-btn .btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.phone-btn {
  background-color: #ffffff;
  color: #667eea;
}

.phone-btn::after {
  border: none;
}

/* 手机号登录 */
.phone-login {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.input-group {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.code-input {
  flex: 1;
  margin-right: 20rpx;
}

.code-btn {
  padding: 12rpx 24rpx;
  background-color: #667eea;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
  line-height: 1.5;
  min-width: 160rpx;
}

.code-btn::after {
  border: none;
}

.code-btn[disabled] {
  background-color: #cccccc;
  color: #999999;
}

/* 用户协议 */
.agreement {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
}

.agreement checkbox {
  transform: scale(0.8);
  margin-right: 8rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.agreement .link {
  color: #ffd700;
  text-decoration: underline;
}

/* 提示信息 */
.tips {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

/* 加载状态 */
.login-btn[disabled] {
  opacity: 0.6;
}
