<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image class="logo" src="/images/icons/logo.png" mode="aspectFit"></image>
    <text class="app-name">{{tAppName}}</text>
    <text class="app-desc">{{tAppDesc}}</text>
  </view>

  <!-- 登录方式选择 -->
  <view class="login-methods">
    <!-- 微信登录 -->
    <view class="wechat-profile-section">
      <view class="input-group">
        <image class="input-icon" src="/images/icons/device.png"></image>
        <input
          class="input"
          placeholder="{{tLoginNickNamePlaceholder}}"
          value="{{nickName}}"
          bindinput="onNickNameInput" />
      </view>
    </view>

    <!-- 微信登录按钮 -->
    <button
      class="login-btn wechat-btn"
      bindtap="onWechatLogin"
      loading="{{wechatLoading}}">
      <image class="btn-icon" src="/images/icons/wechat.png"></image>
      <text>{{tLoginWechatLogin}}</text>
    </button>

    <!-- 手机号登录 -->
    <view class="phone-login">
      <view class="input-group">
        <image class="input-icon" src="/images/icons/phone.png"></image>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="{{tLoginPhonePlaceholder}}"
          value="{{phone}}"
          bindinput="onPhoneInput" />
      </view>

      <view class="input-group">
        <image class="input-icon" src="/images/icons/code.png"></image>
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="{{tLoginCodePlaceholder}}"
          value="{{code}}"
          bindinput="onCodeInput" />
        <button
          class="code-btn"
          bindtap="sendCode"
          disabled="{{counting}}">
          {{counting ? countDown + 's' : tLoginGetVerifyCode}}
        </button>
      </view>

      <button
        class="login-btn phone-btn"
        bindtap="onPhoneLogin"
        loading="{{phoneLoading}}">
        {{tLoginLogin}}
      </button>
    </view>
  </view>

  <!-- 手机号绑定弹窗（微信登录后如果没有手机号则弹出） -->
  <view class="bind-phone-modal" wx:if="{{showBindPhoneModal}}">
    <view class="modal-mask"></view>
    <view class="modal-content">
      <view class="modal-title">{{tLoginBindPhone}}</view>
      <view class="modal-desc">{{tLoginBindPhoneDesc}}</view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/phone.png"></image>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="{{tLoginBindPhonePlaceholder}}"
          value="{{bindPhone}}"
          bindinput="onBindPhoneInput" />
      </view>
      <view class="input-group">
        <image class="input-icon" src="/images/icons/code.png"></image>
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="{{tLoginBindCodePlaceholder}}"
          value="{{bindCode}}"
          bindinput="onBindCodeInput" />
        <button
          class="code-btn"
          bindtap="sendBindCode"
          disabled="{{bindCounting}}">
          {{bindCounting ? bindCountDown + 's' : tLoginGetVerifyCode}}
        </button>
      </view>
      <view class="modal-buttons">
        <button class="modal-btn confirm" bindtap="confirmBindPhone" loading="{{bindLoading}}">{{tLoginBindAndContinue}}</button>
      </view>
    </view>
  </view>

  <!-- 用户协议 -->
  <view class="agreement">
    <checkbox-group bindchange="onAgreementChange">
      <label class="agreement-label">
        <checkbox value="agree" checked="{{agreed}}" />
        <text class="agreement-text">
          {{tLoginAgreeText}}
          <text class="link" bindtap="viewUserAgreement">{{tLoginUserAgreement}}</text>
          {{tLoginAnd}}
          <text class="link" bindtap="viewPrivacyPolicy">{{tLoginPrivacyPolicy}}</text>
        </text>
      </label>
    </checkbox-group>
  </view>

  <!-- 提示信息 -->
  <view class="tips">
    <text class="tip-text">{{tLoginTip1}}</text>
    <text class="tip-text">{{tLoginTip2}}</text>
    <text class="tip-text">{{tLoginTip3}}</text>
  </view>
</view>
