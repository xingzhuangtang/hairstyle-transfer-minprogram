<!--pages/refund-admin/refund-admin.wxml-->
<view class="admin-container">
  <view class="header">
    <text class="title">{{tRaTitle}}</text>
    <text class="subtitle">{{tRaSubtitle}}</text>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" data-tab="0" bindtap="onTabChange">
      <text>{{tRaTabPermission}}</text>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" data-tab="1" bindtap="onTabChange">
      <text>{{tRaTabApplications}}</text>
    </view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" data-tab="2" bindtap="onTabChange">
      <text>{{tRaTabApproved}}</text>
    </view>
  </view>

  <view wx:if="{{currentTab === 0}}">
    <view class="search-bar">
      <input class="search-input" placeholder="{{tRaSearchPlaceholder}}" value="{{searchPhone}}" bindinput="onUserSearchInput" bindconfirm="onUserSearch" type="number" />
      <button class="search-btn" bindtap="onUserSearch">{{tRaSearchBtn}}</button>
    </view>

    <view class="user-list" wx:if="{{users.length > 0}}">
      <view class="user-card" wx:for="{{users}}" wx:key="id">
        <view class="user-info">
          <view class="user-row">
            <text class="user-name">{{item.displayName}}</text>
            <text class="user-tag {{item.refund_enabled ? 'tag-on' : 'tag-off'}}">{{item.refund_enabled ? tRaEnabled : tRaDisabled}}</text>
          </view>
          <view class="user-row">
            <text class="user-detail">{{tRaPhonePrefix}}{{item.displayPhone}}</text>
            <text class="user-detail">{{tRaIdPrefix}}{{item.id}}</text>
          </view>
          <view class="user-row">
            <text class="user-detail">{{item.memberText}}</text>
            <text class="user-detail">{{tRaSilver}}{{item.totalHairs}}</text>
          </view>
        </view>
        <button class="toggle-btn {{item.refund_enabled ? 'btn-off' : 'btn-on'}}"
                data-userid="{{item.id}}" data-index="{{index}}"
                bindtap="onToggleRefund">
          {{item.refund_enabled ? tRaCloseRefund : tRaOpenRefund}}
        </button>
      </view>
    </view>

    <view class="empty-state" wx:if="{{users.length === 0 && !loading}}">
      <text class="empty-icon">👥</text>
      <text class="empty-text">{{tRaSearchHint}}</text>
    </view>

    <view class="load-more" wx:if="{{userHasMore && users.length > 0}}">
      <button class="load-more-btn" bindtap="loadMoreUsers" loading="{{loading}}">{{tRaLoadMore}}</button>
    </view>
  </view>

  <view wx:if="{{currentTab === 1 || currentTab === 2}}">
    <view class="filter-bar" wx:if="{{currentTab === 1}}">
      <view class="filter-item {{appStatusFilter === 'all' ? 'active' : ''}}" data-status="all" bindtap="onAppStatusChange">
        <text>{{tRaAll}}</text>
      </view>
      <view class="filter-item {{appStatusFilter === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="onAppStatusChange">
        <text>{{tRaPending}}</text>
      </view>
      <view class="filter-item {{appStatusFilter === 'approved' ? 'active' : ''}}" data-status="approved" bindtap="onAppStatusChange">
        <text>{{tRaApproved}}</text>
      </view>
      <view class="filter-item {{appStatusFilter === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="onAppStatusChange">
        <text>{{tRaRejected}}</text>
      </view>
    </view>

    <view class="search-bar">
      <input class="search-input" placeholder="{{tRaSearchPlaceholder}}" value="{{appPhoneSearch}}" bindinput="onAppPhoneSearchInput" bindconfirm="onAppPhoneSearch" type="number" />
      <button class="search-btn" bindtap="onAppPhoneSearch">{{tRaSearchBtn}}</button>
    </view>

    <view class="app-list" wx:if="{{applications.length > 0}}">
      <view class="app-card" wx:for="{{applications}}" wx:key="id">
        <view class="app-header">
          <text class="app-user">{{item.user_nickname || item.user_phone || tRaUserPrefix + item.user_id}}</text>
          <text class="app-status {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="app-body">
          <view class="app-row">
            <text class="app-label">{{tRaAmountLabel}}</text>
            <text class="app-value amount">¥{{item.refund_amount}}</text>
          </view>
          <view class="app-row">
            <text class="app-label">{{tRaTypeLabel}}</text>
            <text class="app-value">{{item.refundTypeText}}</text>
          </view>
          <view class="app-row">
            <text class="app-label">{{tRaReasonLabel}}</text>
            <text class="app-value">{{item.reason}}</text>
          </view>
          <view class="app-row">
            <text class="app-label">{{tRaApplicantLabel}}</text>
            <text class="app-value">{{item.applicant_name}} ({{item.applicant_phone}})</text>
          </view>
          <view class="app-row">
            <text class="app-label">{{tRaTimeLabel}}</text>
            <text class="app-value">{{item.formattedCreatedAt}}</text>
          </view>
          <view class="app-row" wx:if="{{item.approved_at}}">
            <text class="app-label">{{tRaProcessTimeLabel}}</text>
            <text class="app-value">{{item.formattedApprovedAt}}</text>
          </view>
          <view class="app-row" wx:if="{{item.status === 'rejected' && item.rejection_reason}}">
            <text class="app-label">{{tRaRejectReasonLabel}}</text>
            <text class="app-value reject">{{item.rejection_reason}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{applications.length === 0 && !appLoading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">{{tRaNoApplications}}</text>
    </view>

    <view class="load-more" wx:if="{{appHasMore && applications.length > 0}}">
      <button class="load-more-btn" bindtap="loadMoreApplications" loading="{{appLoading}}">{{tRaLoadMore}}</button>
    </view>
  </view>
</view>
