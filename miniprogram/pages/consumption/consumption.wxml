<!--pages/consumption/consumption.wxml-->
<view class="consumption-container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'hair' ? 'active' : ''}}" bindtap="onTabChange" data-tab="hair">
      <text>发丝消费</text>
    </view>
    <view class="tab-item {{activeTab === 'money' ? 'active' : ''}}" bindtap="onTabChange" data-tab="money">
      <text>银两消费</text>
    </view>
  </view>

  <!-- 发丝消费 Tab -->
  <view wx:if="{{activeTab === 'hair'}}" class="tab-content">
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-value">{{totalHairConsumed}}</text>
        <text class="stats-label">累计消耗发丝</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{hairRecords.length}}</text>
        <text class="stats-label">消费次数</text>
      </view>
    </view>

    <!-- 筛选标签 -->
    <view class="filter-bar">
      <view class="filter-tag {{hairFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-type="all">全部</view>
      <view class="filter-tag {{hairFilter === 'combined' ? 'active' : ''}}" bindtap="onFilterChange" data-type="combined">一键生成</view>
      <view class="filter-tag {{hairFilter === 'sketch' ? 'active' : ''}}" bindtap="onFilterChange" data-type="sketch">素描转换</view>
      <view class="filter-tag {{hairFilter === 'face_merge' ? 'active' : ''}}" bindtap="onFilterChange" data-type="face_merge">发型融合</view>
    </view>

    <!-- 记录列表 -->
    <scroll-view class="record-list" scroll-y bindscrolltolower="onScrollToLower">
      <view wx:if="{{hairRecords.length === 0 && !loading}}" class="empty-state">
        <text class="empty-text">暂无发丝消费记录</text>
        <text class="empty-desc">使用发型迁移服务后，消费记录将在这里显示</text>
      </view>

      <view wx:for="{{hairRecords}}" wx:key="id" class="record-item">
        <view class="record-left">
          <view class="record-icon {{item.service_type}}">
            <text class="icon-text">{{item.icon}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.service_name}}</text>
            <text class="record-time">{{item.created_at}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount">-{{item.hairs_consumed}}</text>
          <text class="record-status {{item.status === 'success' ? 'status-success' : 'status-failed'}}">{{item.status_text}}</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-state"><text class="loading-text">加载中...</text></view>
      <view wx:if="{{hairNoMore && hairRecords.length > 0}}" class="no-more-state"><text class="no-more-text">没有更多了</text></view>
    </scroll-view>
  </view>

  <!-- 银两消费 Tab -->
  <view wx:if="{{activeTab === 'money'}}" class="tab-content">
    <!-- 筛选标签 -->
    <view class="filter-bar">
      <view class="filter-tag {{moneyFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-type="all">全部</view>
      <view class="filter-tag {{moneyFilter === 'recharge' ? 'active' : ''}}" bindtap="onFilterChange" data-type="recharge">充值</view>
      <view class="filter-tag {{moneyFilter === 'member_purchase' ? 'active' : ''}}" bindtap="onFilterChange" data-type="member_purchase">会员</view>
      <view class="filter-tag {{moneyFilter === 'refund' ? 'active' : ''}}" bindtap="onFilterChange" data-type="refund">退款</view>
      <view class="filter-tag {{moneyFilter === 'commission' ? 'active' : ''}}" bindtap="onFilterChange" data-type="commission">佣金</view>
    </view>

    <!-- 记录列表 -->
    <scroll-view class="record-list" scroll-y bindscrolltolower="onScrollToLower">
      <view wx:if="{{moneyRecords.length === 0 && !loading}}" class="empty-state">
        <text class="empty-text">暂无银两消费记录</text>
        <text class="empty-desc">充值、会员、退款、推广佣金等资金流水将在这里显示</text>
      </view>

      <view wx:for="{{moneyRecords}}" wx:key="id" class="record-item">
        <view class="record-left">
          <view class="record-icon money-icon">
            <text class="icon-text" style="color: {{item.color}}">{{item.icon}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.type_name}}</text>
            <text class="record-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <text class="record-time">{{item.created_at}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount {{item.amount >= 0 ? 'amount-positive' : 'amount-negative'}}">{{item.amount_text}}</text>
          <text class="record-status {{item.status === 'success' ? 'status-success' : item.status === 'pending' ? 'status-pending' : 'status-failed'}}">{{item.status_text}}</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-state"><text class="loading-text">加载中...</text></view>
      <view wx:if="{{moneyNoMore && moneyRecords.length > 0}}" class="no-more-state"><text class="no-more-text">没有更多了</text></view>
    </scroll-view>
  </view>
</view>
