<!--pages/consumption/consumption.wxml-->
<view class="consumption-container">
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-value">{{totalConsumed}}</text>
      <text class="stats-label">累计消耗</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-value">{{totalCount}}</text>
      <text class="stats-label">消费次数</text>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view class="filter-item {{activeFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-type="all">
      全部
    </view>
    <view class="filter-item {{activeFilter === 'hair_segment' ? 'active' : ''}}" bindtap="onFilterChange" data-type="hair_segment">
      发型提取
    </view>
    <view class="filter-item {{activeFilter === 'face_merge' ? 'active' : ''}}" bindtap="onFilterChange" data-type="face_merge">
      发型融合
    </view>
    <view class="filter-item {{activeFilter === 'sketch' ? 'active' : ''}}" bindtap="onFilterChange" data-type="sketch">
      素描转换
    </view>
    <view class="filter-item {{activeFilter === 'combined' ? 'active' : ''}}" bindtap="onFilterChange" data-type="combined">
      一键生成
    </view>
  </view>

  <!-- 消费记录列表 -->
  <scroll-view class="record-list" scroll-y bindscrolltolower="onScrollToLower">
    <!-- 空状态 -->
    <view wx:if="{{records.length === 0 && !loading}}" class="empty-state">
      <image class="empty-icon" src="/images/empty-device.svg" mode="aspectFit"></image>
      <text class="empty-text">暂无消费记录</text>
      <text class="empty-desc">使用发型迁移服务后，消费记录将在这里显示</text>
    </view>

    <!-- 记录列表 -->
    <block wx:else>
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-left">
          <view class="record-icon {{item.service_type}}">
            <text class="icon-text">{{item.icon}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.service_name}}</text>
            <text class="record-time">{{item.created_at}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount">-{{item.hairs_consumed}}</text>
          <text class="record-status {{item.status}}">{{item.status_text}}</text>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more-state" wx:if="{{noMore && records.length > 0}}">
      <text class="no-more-text">没有更多记录了</text>
    </view>
  </scroll-view>
</view>
