<!--pages/consumption/consumption.wxml-->
<view class="consumption-container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'hair' ? 'active' : ''}}" bindtap="onTabChange" data-tab="hair">
      <text>{{tConsHairTab}}</text>
    </view>
    <view class="tab-item {{activeTab === 'money' ? 'active' : ''}}" bindtap="onTabChange" data-tab="money">
      <text>{{tConsMoneyTab}}</text>
    </view>
  </view>

  <!-- 发丝消费 Tab -->
  <view wx:if="{{activeTab === 'hair'}}" class="tab-content">
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-value">{{totalHairConsumed}}</text>
        <text class="stats-label">{{tConsTotalConsumed}}</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{hairRecords.length}}</text>
        <text class="stats-label">{{tConsumptionCount}}</text>
      </view>
    </view>

    <!-- 筛选标签 -->
    <view class="filter-bar">
      <view class="filter-tag {{hairFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-type="all">{{tConsFilterAll}}</view>
      <view class="filter-tag {{hairFilter === 'combined' ? 'active' : ''}}" bindtap="onFilterChange" data-type="combined">{{tConsFilterCombined}}</view>
      <view class="filter-tag {{hairFilter === 'sketch' ? 'active' : ''}}" bindtap="onFilterChange" data-type="sketch">{{tConsFilterSketch}}</view>
      <view class="filter-tag {{hairFilter === 'face_merge' ? 'active' : ''}}" bindtap="onFilterChange" data-type="face_merge">{{tConsFilterFaceMerge}}</view>
    </view>

    <!-- 记录列表 -->
    <scroll-view class="record-list" scroll-y bindscrolltolower="onScrollToLower">
      <view wx:if="{{hairRecords.length === 0 && !loading}}" class="empty-state">
        <text class="empty-text">{{tConsEmptyHair}}</text>
        <text class="empty-desc">{{tConsEmptyHairTip}}</text>
      </view>

      <view wx:for="{{hairRecords}}" wx:key="id" class="record-item">
        <view class="record-left">
          <view class="record-icon {{item.service_type}}">
            <text class="icon-text">{{item.icon}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.service_name}}</text>
            <text class="record-time">{{item.created_at}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount">-{{item.hairs_consumed}}</text>
          <text class="record-status {{item.status === 'success' ? 'status-success' : 'status-failed'}}">{{item.status_text}}</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-state"><text class="loading-text">{{tConsLoadingText}}</text></view>
      <view wx:if="{{hairNoMore && hairRecords.length > 0}}" class="no-more-state"><text class="no-more-text">{{tConsNoMore}}</text></view>
    </scroll-view>
  </view>

  <!-- 银两消费 Tab -->
  <view wx:if="{{activeTab === 'money'}}" class="tab-content">
    <!-- 筛选标签 -->
    <view class="filter-bar">
      <view class="filter-tag {{moneyFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-type="all">{{tConsFilterAll}}</view>
      <view class="filter-tag {{moneyFilter === 'recharge' ? 'active' : ''}}" bindtap="onFilterChange" data-type="recharge">{{tConsFilterRecharge}}</view>
      <view class="filter-tag {{moneyFilter === 'member_purchase' ? 'active' : ''}}" bindtap="onFilterChange" data-type="member_purchase">{{tConsFilterMember}}</view>
      <view class="filter-tag {{moneyFilter === 'refund' ? 'active' : ''}}" bindtap="onFilterChange" data-type="refund">{{tConsFilterRefund}}</view>
      <view class="filter-tag {{moneyFilter === 'commission' ? 'active' : ''}}" bindtap="onFilterChange" data-type="commission">{{tConsFilterCommission}}</view>
    </view>

    <!-- 记录列表 -->
    <scroll-view class="record-list" scroll-y bindscrolltolower="onScrollToLower">
      <view wx:if="{{moneyRecords.length === 0 && !loading}}" class="empty-state">
        <text class="empty-text">{{tConsEmptyMoney}}</text>
        <text class="empty-desc">{{tConsEmptyMoneyTip}}</text>
      </view>

      <view wx:for="{{moneyRecords}}" wx:key="id" class="record-item">
        <view class="record-left">
          <view class="record-icon money-icon">
            <text class="icon-text" style="color: {{item.color}}">{{item.icon}}</text>
          </view>
          <view class="record-info">
            <text class="record-title">{{item.type_name}}</text>
            <text class="record-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <text class="record-time">{{item.created_at}}</text>
          </view>
        </view>
        <view class="record-right">
          <text class="record-amount {{item.amount >= 0 ? 'amount-positive' : 'amount-negative'}}">{{item.amount_text}}</text>
          <text class="record-status {{item.status === 'success' ? 'status-success' : item.status === 'pending' ? 'status-pending' : 'status-failed'}}">{{item.status_text}}</text>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-state"><text class="loading-text">{{tConsLoadingText}}</text></view>
      <view wx:if="{{moneyNoMore && moneyRecords.length > 0}}" class="no-more-state"><text class="no-more-text">{{tConsNoMore}}</text></view>
    </scroll-view>
  </view>
</view>
