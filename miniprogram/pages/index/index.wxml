<!--pages/index/index.wxml-->
<view class="index-container">
  <!-- 余额显示区域 -->
  <view class="balance-section" wx:if="{{isLoggedIn}}">
    <view class="balance-item">
      <text class="balance-value">{{combHairs}}</text>
      <text class="balance-label">{{tIndexComb}}</text>
    </view>
    <view class="balance-divider"></view>
    <view class="balance-item">
      <text class="balance-value">{{scissorHairs}}</text>
      <text class="balance-label">{{tIndexScissor}}</text>
    </view>
    <view class="balance-divider"></view>
    <view class="balance-item total">
      <text class="balance-value">{{totalHairs}}</text>
      <text class="balance-label">{{tIndexTotal}}</text>
    </view>
    <view class="vip-badge" wx:if="{{isPremium}}">
      <text>{{tIndexVipDiscount}}</text>
    </view>
  </view>

  <!-- 访客提示 -->
  <view class="guest-tip" wx:if="{{!isLoggedIn}}">
    <text class="guest-tip-icon">👤</text>
    <text class="guest-tip-text">{{tIndexGuestTip}}</text>
    <text class="guest-tip-link" bindtap="goToLogin">{{tIndexLoginMore}}</text>
  </view>

  <!-- 游客账号信息卡片 -->
  <view class="device-card" wx:if="{{!isLoggedIn}}">
    <view class="device-card-header">
      <image class="device-card-icon" src="/images/icons/device.png"></image>
      <text class="device-card-title">{{tIndexMyAccount}}</text>
    </view>
    <view class="device-card-body">
      <view class="device-info-row">
        <text class="device-info-label">{{tIndexDeviceName}}</text>
        <text class="device-info-value">{{deviceName}}</text>
      </view>
      <view class="device-info-row">
        <text class="device-info-label">{{tIndexAccountId}}</text>
        <text class="device-info-value device-id">{{accountId || tIndexShowAfterLogin}}</text>
      </view>
    </view>
    <view class="device-card-tip">
      <text>{{tIndexAccountIdTip}}</text>
    </view>
  </view>

  <!-- 图片上传区域 -->
  <view class="upload-section">
    <!-- 发型参考图 -->
    <view class="upload-item">
      <text class="upload-label">{{tIndexHairstyleRef}}</text>
      <view class="upload-box" bindtap="chooseHairstyleImage">
        <image wx:if="{{hairstyleUrl}}" class="preview-image" src="{{hairstyleUrl}}" mode="widthFix" show-menu-by-longpress lazy-load binderror="imageError" bindload="imageLoad"></image>
        <view wx:else class="upload-placeholder">
          <image class="upload-icon" src="/images/icons/upload.png"></image>
          <text class="upload-text">{{tIndexClickUpload}}</text>
        </view>
        <image wx:if="{{hairstyleUrl}}" class="delete-icon" src="/images/icons/close.png" catchtap="deleteHairstyleImage"></image>
      </view>
    </view>

    <!-- 客户照片 -->
    <view class="upload-item">
      <text class="upload-label">{{tIndexCustomerPhoto}}</text>
      <view class="upload-box" bindtap="chooseCustomerImage">
        <image wx:if="{{customerUrl}}" class="preview-image" src="{{customerUrl}}" mode="widthFix" show-menu-by-longpress lazy-load binderror="imageError" bindload="imageLoad"></image>
        <view wx:else class="upload-placeholder">
          <image class="upload-icon" src="/images/icons/upload.png"></image>
          <text class="upload-text">{{tIndexClickUpload}}</text>
        </view>
        <image wx:if="{{customerUrl}}" class="delete-icon" src="/images/icons/close.png" catchtap="deleteCustomerImage"></image>
      </view>
    </view>
  </view>

  <!-- 参数调节区域 -->
  <view class="params-section">
    <!-- 处理模式切换 -->
    <view class="param-item">
      <text class="param-label">{{tIndexProcessingMode}}</text>
      <view class="param-value">
        <picker mode="selector" range="{{modePickerRange}}" value="{{modeIndex}}" bindchange="onModeChange">
          <view class="picker">
            {{modePickerDisplay}}
            <image class="arrow-icon" src="/images/icons/arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>
    <!-- 模型版本 -->
    <view class="param-item">
      <text class="param-label">{{tIndexModelVersion}}</text>
      <view class="param-value">
        <picker mode="selector" range="{{modelVersionPickerRange}}" value="{{modelVersionIndex}}" bindchange="onModelVersionChange">
          <view class="picker">
            {{modelVersionPickerDisplay}}
            <image class="arrow-icon" src="/images/icons/arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>

    <!-- 脸型融合度 -->
    <view class="param-item">
      <text class="param-label">{{tIndexFaceFusion}}</text>
      <view class="slider-container">
        <slider
          class="slider"
          min="0"
          max="100"
          value="{{fusionDegree}}"
          bindchange="onFusionDegreeChange"
          activeColor="#667eea"
          backgroundColor="#e0e0e0"
          block-size="20" />
        <text class="slider-value">{{fusionDegree}}%</text>
      </view>
    </view>

    <!-- 素描效果（分步模式下禁用） -->
    <view class="param-item">
      <text class="param-label">{{tIndexSketchEffect}}</text>
      <switch
        class="switch"
        checked="{{enableSketch}}"
        bindchange="onSketchChange"
        disabled="{{modeIndex === 1}}"
        color="#667eea" />
    </view>

    <!-- 素描风格（素描开启时显示） -->
    <view class="param-item" wx:if="{{enableSketch}}">
      <text class="param-label">{{tIndexSketchStyle}}</text>
      <view class="param-value">
        <picker mode="selector" range="{{sketchStyles}}" range-key="label" value="{{sketchStyleIndex}}" bindchange="onSketchStyleChange">
          <view class="picker">
            {{sketchStyles[sketchStyleIndex].label}}
            <image class="arrow-icon" src="/images/icons/arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <!-- 分步模式：结果预览 -->
    <view class="step-result" wx:if="{{modeIndex === 1}}">
      <text class="step-label" wx:if="{{!hasResult}}">{{tIndexPrepareFirst}}</text>
      <text class="step-label" wx:if="{{hasResult}}">{{tIndexStep1Done}}</text>
      <image wx:if="{{hasResult}}" class="step-image" src="{{resultUrl}}" mode="widthFix" show-menu-by-longpress bindtap="enlargeImage" data-src="{{resultUrl}}"></image>
    </view>

    <view class="cost-info">
      <text wx:if="{{currentCost > 0}}" class="cost-text">
        {{tIndexEstimatedCostPrefix}}：{{currentCost}}{{tIndexHairs}}
        <text wx:if="{{isPremium}}" class="discount-text">({{tIndexMemberDiscount}})</text>
      </text>
    </view>

    <!-- 综合模式按钮 -->
    <view class="action-buttons" wx:if="{{modeIndex === 0}}">
      <button class="action-btn secondary" bindtap="extractOnly" disabled="{{processing}}">
        {{tIndexExtractOnly}}
        <text class="cost">{{isPremium ? extractCost : extractCostNormal}} {{tIndexHairs}}</text>
      </button>
      <button class="action-btn secondary" bindtap="transferOnly" disabled="{{processing}}">
        {{tIndexTransferOnly}}
        <text class="cost">{{isPremium ? transferCost : transferCostNormal}} {{tIndexHairs}}</text>
      </button>
      <button class="action-btn primary" bindtap="processAll" disabled="{{processing}}">
        {{tIndexSketchOptimize}}
        <text class="cost">{{allCost}}{{tIndexHairs}}</text>
      </button>
    </view>

    <!-- 分步模式按钮 -->
    <view class="action-buttons" wx:if="{{modeIndex === 1}}">
      <button class="action-btn secondary" bindtap="extractOnly" disabled="{{processing}}">
        {{tIndexExtractOnly}}
        <text class="cost">{{isPremium ? extractCost : extractCostNormal}} {{tIndexHairs}}</text>
      </button>
      <button class="action-btn secondary" bindtap="transferOnly" disabled="{{processing}}">
        {{tIndexGenerateHair}}
        <text class="cost">{{isPremium ? transferCost : transferCostNormal}} {{tIndexHairs}}</text>
      </button>
      <button class="action-btn primary" bindtap="addSketchOnly" disabled="{{processing || !hasResult}}">
        {{tIndexSketchOptimize}}
        <text class="cost">{{isPremium ? sketchCost : sketchCostNormal}}{{tIndexHairs}}</text>
      </button>
    </view>
  </view>

  <!-- 会员提示 -->
  <view class="vip-tip" wx:if="{{!isPremium}}">
    <text class="tip-icon">👑</text>
    <text class="tip-text">{{tIndexMemberTip}}</text>
    <text class="tip-link" bindtap="goToMember">{{tIndexUpgradeNow}}</text>
  </view>
</view>

<!-- 加载弹窗 -->
<view class="loading-modal" wx:if="{{processing}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{processingText}}</text>
  </view>
</view>
