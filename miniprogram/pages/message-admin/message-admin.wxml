<!--pages/message-admin/message-admin.wxml-->
<view class="admin-container">
  <view class="header">
    <text class="title">{{tMsgAdminTitle}}</text>
    <text class="subtitle">{{tMsgAdminTotal}}</text>
  </view>

  <!-- 留言列表 -->
  <view class="message-list" wx:if="{{messages.length > 0}}">
    <view class="message-item" wx:for="{{messages}}" wx:key="id">
      <view class="message-header">
        <text class="name">{{item.name}}</text>
        <text class="phone" bindtap="copyPhone" data-phone="{{item.phone}}">{{item.phone}} 📋</text>
      </view>
      <view class="message-content">{{item.content}}</view>
      <view class="message-footer">
        <text class="time">{{item.created_at}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{messages.length === 0 && !loading}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">{{tMsgAdminEmpty}}</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && messages.length > 0}}">
    <button class="load-more-btn" bindtap="loadMore" loading="{{loading}}">
      {{tMsgAdminLoadMore}}
    </button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && messages.length === 0}}">
    <text class="loading-text">{{tMsgAdminLoading}}</text>
  </view>
</view>
