<!--pages/history/history.wxml-->
<view class="history-container">
  <view class="header">
    <view class="header-title">{{tHistoryTitle}}</view>
    <view class="header-desc" wx:if="{{isVip}}">{{tHistoryHeaderDescVip}}</view>
    <view class="header-desc" wx:else>{{tHistoryHeaderDescNonVip}}</view>
  </view>

  <view class="vip-notice" wx:if="{{!isVip}}" bindtap="goToMember">
    <view class="vip-notice-content">
      <view class="vip-icon">👑</view>
      <view class="vip-text">
        <text class="vip-title">{{tHistoryOpenVipNotice}}</text>
        <text class="vip-desc">{{tHistoryVipBenefitDesc}}</text>
      </view>
      <view class="vip-arrow">></view>
    </view>
  </view>

  <view class="history-list" wx:if="{{isVip}}">
    <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">{{tHistoryEmptyText}}</view>
      <view class="empty-desc">{{tHistoryEmptyDesc}}</view>
    </view>

    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <view class="loading-text">{{tHistoryLoadingText}}</view>
    </view>

    <view wx:for="{{records}}" wx:key="id" class="history-item">
      <view class="item-preview-group">
        <view class="preview-item" 
              catchtap="showDownloadMenu" 
              data-id="{{item.id}}" 
              data-type="result">
          <image src="{{item.result_image}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" data-type="result" />
          <view class="preview-label">{{tHistoryResultLabel}}</view>
        </view>
        
        <view wx:if="{{item.has_sketch}}" 
              class="preview-item" 
              catchtap="showDownloadMenu" 
              data-id="{{item.id}}" 
              data-type="sketch">
          <image src="{{item.sketch_image}}" mode="aspectFill" lazy-load binderror="onSketchError" data-index="{{index}}" data-type="sketch" />
          <view class="preview-label">{{tHistorySketchLabel}}</view>
        </view>
        <view wx:else class="preview-item preview-placeholder">
          <view class="placeholder-text">{{tHistoryNoSketch}}</view>
        </view>
      </view>
      
      <view class="item-info">
        <view class="item-title">
          <text class="service-type">{{item.service_type_text}}</text>
          <text class="record-id">#{{item.id}}</text>
        </view>
        <view class="item-time">{{item.created_at}}</view>
        <view class="item-countdown {{item.countdown_class}}">
          {{item.countdown_text}}
        </view>
      </view>
      <view class="item-arrow" bindtap="viewDetail" data-id="{{item.id}}">></view>
    </view>
  </view>

  <view class="non-premium-list" wx:if="{{!isVip}}">
    <view class="feature-item">
      <view class="feature-icon">📸</view>
      <view class="feature-text">
        <view class="feature-title">{{tHistoryFeature1Title}}</view>
        <view class="feature-desc">{{tHistoryFeature1Desc}}</view>
      </view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">⏰</view>
      <view class="feature-text">
        <view class="feature-title">{{tHistoryFeature2Title}}</view>
        <view class="feature-desc">{{tHistoryFeature2Desc}}</view>
      </view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">💾</view>
      <view class="feature-text">
        <view class="feature-title">{{tHistoryFeature3Title}}</view>
        <view class="feature-desc">{{tHistoryFeature3Desc}}</view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{hasMore && isVip}}">
    <button class="load-more-btn" bindtap="loadMore">{{tHistoryLoadMore}}</button>
  </view>

  <canvas canvas-id="combinedCanvas" style="position:fixed;left:-9999px;top:-9999px;width:{{canvasWidth||1080}}px;height:{{canvasHeight||2000}}px;"></canvas>
</view>
