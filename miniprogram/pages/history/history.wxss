.history-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
}

.content {
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.desc {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.vip-tip {
  display: block;
  font-size: 26rpx;
  color: #ff6600;
  padding: 20rpx 40rpx;
  background-color: #fff5e6;
  border-radius: 12rpx;
}
