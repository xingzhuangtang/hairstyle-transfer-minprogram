/* pages/history/history.wxss */

.history-container {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx 60rpx;
  text-align: center;
}

.header-title {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.header-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  display: block;
}

.vip-notice {
  margin: -30rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.vip-notice-content {
  display: flex;
  align-items: center;
}

.vip-icon { font-size: 48rpx; margin-right: 16rpx; }
.vip-text { flex: 1; }
.vip-title { color: #333; font-size: 30rpx; font-weight: bold; margin-bottom: 6rpx; display: block; }
.vip-desc { color: #999; font-size: 24rpx; display: block; }
.vip-arrow { color: #ccc; font-size: 28rpx; }

.history-list { padding: 0 30rpx; }

.empty-state { text-align: center; padding: 120rpx 30rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { color: #333; font-size: 30rpx; margin-bottom: 10rpx; }
.empty-desc { color: #999; font-size: 26rpx; line-height: 1.6; }

.loading-state { text-align: center; padding: 80rpx 0; }
.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: #999; font-size: 26rpx; }

.history-item {
  display: flex; align-items: center;
  background: #fff; border-radius: 16rpx;
  padding: 20rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-preview-group {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.preview-item {
  position: relative;
  width: 100rpx; height: 100rpx;
  border-radius: 12rpx; overflow: hidden;
  background: #f5f5f5;
}
.preview-item:active {
  opacity: 0.7;
}
.preview-item image { width: 100%; height: 100%; }

.preview-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

.preview-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
}
.placeholder-text {
  color: #ccc;
  font-size: 22rpx;
}

.item-info { flex: 1; margin-left: 16rpx; overflow: hidden; }
.item-title { 
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.service-type {
  color: #667eea;
  font-size: 26rpx;
  font-weight: 500;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.record-id {
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
}
.item-time { color: #999; font-size: 24rpx; margin-bottom: 8rpx; }

.item-countdown { 
  display: inline-block; 
  padding: 4rpx 12rpx; 
  border-radius: 8rpx; 
  font-size: 22rpx; 
  font-weight: 500;
}
.item-countdown.valid { 
  background: rgba(76, 217, 100, 0.1); 
  color: #4cd964; 
}
.item-countdown.warning { 
  background: rgba(255, 204, 0, 0.1); 
  color: #ffcc00; 
}
.item-countdown.urgent { 
  background: rgba(255, 149, 0, 0.1); 
  color: #ff9500; 
}
.item-countdown.expired { 
  background: rgba(255, 59, 48, 0.1); 
  color: #ff3b30; 
}
.item-arrow { color: #ccc; font-size: 28rpx; margin-left: 10rpx; }

.non-premium-list { padding: 40rpx 30rpx; }
.feature-item { display: flex; align-items: center; background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.feature-icon { font-size: 60rpx; margin-right: 20rpx; }
.feature-text { flex: 1; }
.feature-title { color: #333; font-size: 30rpx; font-weight: 500; margin-bottom: 6rpx; }
.feature-desc { color: #999; font-size: 26rpx; }

.load-more { text-align: center; padding: 30rpx; }
.load-more-btn {
  background: #fff; color: #667eea;
  font-size: 28rpx; border-radius: 40rpx;
  padding: 20rpx 80rpx; border: 2rpx solid #667eea;
}
.load-more-btn::after { border: none; }
