.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #ff4d4f;
}

.radio-group {
  display: flex;
  gap: 32rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
}

.currency {
  font-size: 32rpx;
  color: #333;
  margin-right: 8rpx;
}

.amount-input {
  flex: 1;
  font-size: 32rpx;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.input-row .label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.input-row .input {
  flex: 1;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.submit-wrapper {
  padding: 40rpx 0;
}

.submit-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 8rpx;
  padding: 20rpx 0;
}

.submit-btn.disabled {
  background: #ccc;
}
