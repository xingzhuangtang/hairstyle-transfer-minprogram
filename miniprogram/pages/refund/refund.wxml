<view class="container">
  <view class="form-section">
    <view class="section-title">{{tRefundTypeLabel}}</view>
    <radio-group class="radio-group" bindchange="onRefundTypeChange">
      <label class="radio-item">
        <radio value="recharge" checked="{{refundType === 'recharge'}}"/>
        <text>{{tRefundRecharge}}</text>
      </label>
      <label class="radio-item">
        <radio value="membership" checked="{{refundType === 'membership'}}"/>
        <text>{{tRefundMembership}}</text>
      </label>
    </radio-group>
  </view>

  <view class="form-section">
    <view class="section-title">{{tRefundAmountLabel}}</view>

    <block wx:if="{{refundType === 'recharge'}}">
      <view wx:if="{{loadingOptions}}" class="picker-wrapper loading">
        <text>{{tRefundLoadingOpts}}</text>
      </view>
      <block wx:else>
        <view wx:if="{{rechargeOptions.length === 0}}" class="picker-wrapper empty">
          <text>{{tRefundNoRecords}}</text>
        </view>
        <block wx:else>
          <picker mode="selector" range="{{rechargePickerRange}}" bindchange="onRechargeSelect" disabled="{{rechargeOptions.length === 0}}">
            <view class="picker-wrapper {{selectedOptionIndex >= 0 ? 'selected' : ''}}">
              <text wx:if="{{selectedOptionIndex >= 0}}" class="picker-value">¥{{refundAmount}}</text>
              <text wx:else class="picker-placeholder">{{tRefundSelectRecord}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </block>
      </block>
    </block>

    <block wx:if="{{refundType === 'membership'}}">
      <view class="input-wrapper">
        <text class="currency">¥</text>
        <input class="amount-input" type="digit" placeholder="{{tRefundMembershipPlaceholder}}" value="{{refundAmount}}" disabled="true" />
      </view>
      <view class="hint">{{tRefundMembershipAuto}}</view>
    </block>
  </view>

  <view class="form-section">
    <view class="section-title">{{tRefundReasonLabel}} <text class="required">*</text></view>
    <textarea class="textarea" placeholder="{{tRefundReasonPlaceholder}}" value="{{reason}}" bindinput="onReasonInput" maxlength="500" />
    <view class="char-count">{{reason.length}}/500</view>
  </view>

  <view class="form-section">
    <view class="section-title">{{tRefundSuggestionsLabel}}</view>
    <textarea class="textarea" placeholder="{{tRefundSuggestionsPlaceholder}}" value="{{suggestions}}" bindinput="onSuggestionsInput" maxlength="500" />
  </view>

  <view class="form-section">
    <view class="section-title">{{tRefundApplicantInfo}}</view>
    <view class="input-row">
      <text class="label">{{tRefundNameLabel}}</text>
      <input class="input" placeholder="{{tRefundNamePlaceholder}}" value="{{applicantName}}" bindinput="onNameInput" />
    </view>
    <view class="input-row">
      <text class="label">{{tRefundPhoneLabel}}</text>
      <input class="input" type="number" placeholder="{{tRefundPhonePlaceholder}}" value="{{applicantPhone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">{{tRefundCalcSection}}</view>
    <view class="hint" style="margin-bottom: 16rpx;">{{tRefundCalcHint}}</view>
    <button class="calculate-btn {{calculating ? 'disabled' : ''}}" bindtap="onCalculateTap" disabled="{{calculating}}">
      {{calculating ? tRefundCalculating : tRefundCalcBtn}}
    </button>
  </view>

  <view class="calculation-panel" wx:if="{{showCalculation && calculation}}">
    <view class="calculation-header">
      <text class="calculation-title">{{tRefundCalcTitle}}</text>
      <text class="close-btn" bindtap="onCloseCalculation">×</text>
    </view>
    
    <view class="calculation-content">
      <block wx:if="{{calculation.refund_type === 'recharge'}}">
        <view class="calc-row">
          <text class="calc-label">{{tRefundChargeAmount}}</text>
          <text class="calc-value">¥{{calculation.charge_amount}}</text>
        </view>
        <view class="calc-row">
          <text class="calc-label">{{tRefundChargeHairs}}</text>
          <text class="calc-value">{{calculation.charge_hairs}} {{tRefundHairsUnit}}</text>
        </view>
        <view class="calc-row">
          <text class="calc-label">{{tRefundApplyAmount}}</text>
          <text class="calc-value">¥{{calculation.refund_amount_requested}}</text>
        </view>
      </block>
      
      <block wx:if="{{calculation.refund_type === 'membership'}}">
        <view class="calc-row">
          <text class="calc-label">{{tRefundMemberPrice}}</text>
          <text class="calc-value">¥{{calculation.member_price}}</text>
        </view>
        <view class="calc-row">
          <text class="calc-label">{{tRefundRemainingDays}}</text>
          <text class="calc-value">{{calculation.remaining_days}} {{tRefundDaysUnit}}</text>
        </view>
        <view class="calc-row">
          <text class="calc-label">{{tRefundAmountDue}}</text>
          <text class="calc-value">¥{{calculation.refund_amount_requested}}</text>
        </view>
      </block>
      
      <view class="calc-divider"></view>
      
      <view class="calc-row">
        <text class="calc-label">{{tRefundDeductHairs}}</text>
        <text class="calc-value">{{calculation.hairs_to_deduct}} {{tRefundHairsUnit}}</text>
      </view>
      <view class="calc-row">
        <text class="calc-label">{{tRefundCurrentScissor}}</text>
        <text class="calc-value">{{calculation.scissor_hairs}} {{tRefundHairsUnit}}</text>
      </view>
      <view class="calc-row">
        <text class="calc-label">{{tRefundCurrentComb}}</text>
        <text class="calc-value">{{calculation.comb_hairs}} {{tRefundHairsUnit}}</text>
      </view>
      
      <block wx:if="{{!calculation.hairs_sufficient}}">
        <view class="calc-row warning">
          <text class="calc-label">{{tRefundHairShortage}}</text>
          <text class="calc-value">-{{calculation.missing_hairs}} {{tRefundHairsUnit}}</text>
        </view>
        <view class="calc-row warning">
          <text class="calc-label">{{tRefundCashDeduction}}</text>
          <text class="calc-value">¥{{calculation.cash_deduction}}</text>
        </view>
      </block>
      
      <view class="calc-divider"></view>
      <view class="calc-row result {{calculation.hairs_sufficient ? 'success' : 'warning'}}">
        <text class="calc-label">{{tRefundFinalRefund}}</text>
        <text class="calc-value amount">¥{{calculation.actual_refund}}</text>
      </view>
      
      <view class="calc-tip" wx:if="{{calculation.hairs_sufficient}}">✅ {{tRefundSufficientTip}}</view>
      <view class="calc-tip warning" wx:if="{{!calculation.hairs_sufficient}}">⚠️ {{tRefundInsufficientTip}}</view>
    </view>
  </view>

  <view class="submit-wrapper">
    <button class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? tRefundSubmitting : tRefundSubmitBtn}}
    </button>
  </view>
</view>
