<view class="container">
  <!-- 退款类型选择 -->
  <view class="form-section">
    <view class="section-title">退款类型</view>
    <radio-group class="radio-group" bindchange="onRefundTypeChange">
      <label class="radio-item">
        <radio value="recharge" checked="{{refundType === 'recharge'}}"/>
        <text>充值退款</text>
      </label>
      <label class="radio-item">
        <radio value="membership" checked="{{refundType === 'membership'}}"/>
        <text>会员退款</text>
      </label>
    </radio-group>
  </view>

  <!-- 退款金额 -->
  <view class="form-section">
    <view class="section-title">退款金额</view>
    <view class="input-wrapper">
      <text class="currency">¥</text>
      <input 
        class="amount-input" 
        type="digit" 
        placeholder="请输入退款金额" 
        value="{{refundAmount}}"
        bindinput="onAmountInput"
        disabled="{{refundType === 'membership'}}"
      />
    </view>
    <view class="hint" wx:if="{{refundType === 'membership'}}">
      会员退款将按剩余天数自动计算可退金额
    </view>
  </view>

  <!-- 退款原因 -->
  <view class="form-section">
    <view class="section-title">退款原因 <text class="required">*</text></view>
    <textarea 
      class="textarea" 
      placeholder="请详细说明退款原因" 
      value="{{reason}}"
      bindinput="onReasonInput"
      maxlength="500"
    />
    <view class="char-count">{{reason.length}}/500</view>
  </view>

  <!-- 对本项目的建议 -->
  <view class="form-section">
    <view class="section-title">对本项目的建议（选填）</view>
    <textarea 
      class="textarea" 
      placeholder="您的建议对我们很重要" 
      value="{{suggestions}}"
      bindinput="onSuggestionsInput"
      maxlength="500"
    />
  </view>

  <!-- 申请人信息 -->
  <view class="form-section">
    <view class="section-title">申请人信息</view>
    <view class="input-row">
      <text class="label">姓名</text>
      <input 
        class="input" 
        placeholder="请输入姓名" 
        value="{{applicantName}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="input-row">
      <text class="label">电话</text>
      <input 
        class="input" 
        type="number" 
        placeholder="请输入手机号" 
        value="{{applicantPhone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-wrapper">
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}" 
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交退款申请'}}
    </button>
  </view>
</view>
