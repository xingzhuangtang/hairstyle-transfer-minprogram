<view class="container">
  <!-- 退款类型选择 -->
  <view class="form-section">
    <view class="section-title">{{tRefundRefundType}}</view>
    <radio-group class="radio-group" bindchange="onRefundTypeChange">
      <label class="radio-item">
        <radio value="recharge" checked="{{refundType === 'recharge'}}"/>
        <text>{{tRefundRechargeRefund}}</text>
      </label>
      <label class="radio-item">
        <radio value="membership" checked="{{refundType === 'membership'}}"/>
        <text>{{tRefundMembershipRefund}}</text>
      </label>
    </radio-group>
  </view>

  <!-- 退款金额 -->
  <view class="form-section">
    <view class="section-title">{{tRefundRefundAmount}}</view>
    <view class="input-wrapper">
      <text class="currency">¥</text>
      <input
        class="amount-input"
        type="digit"
        placeholder="{{tRefundAmountPlaceholder}}"
        value="{{refundAmount}}"
        bindinput="onAmountInput"
        disabled="{{refundType === 'membership'}}"
      />
    </view>
    <view class="hint" wx:if="{{refundType === 'membership'}}">
      {{tRefundMembershipAutoCalc}}
    </view>
  </view>

  <!-- 退款原因 -->
  <view class="form-section">
    <view class="section-title">{{tRefundReasonLabel}} <text class="required">*</text></view>
    <textarea
      class="textarea"
      placeholder="{{tRefundReasonPlaceholder}}"
      value="{{reason}}"
      bindinput="onReasonInput"
      maxlength="500"
    />
    <view class="char-count">{{reason.length}}/500</view>
  </view>

  <!-- 对本项目的建议 -->
  <view class="form-section">
    <view class="section-title">{{tRefundSuggestionsLabel}}</view>
    <textarea
      class="textarea"
      placeholder="{{tRefundSuggestionsPlaceholder}}"
      value="{{suggestions}}"
      bindinput="onSuggestionsInput"
      maxlength="500"
    />
  </view>

  <!-- 申请人信息 -->
  <view class="form-section">
    <view class="section-title">{{tRefundApplicantInfo}}</view>
    <view class="input-row">
      <text class="label">{{tRefundNameLabel}}</text>
      <input
        class="input"
        placeholder="{{tRefundNamePlaceholder}}"
        value="{{applicantName}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="input-row">
      <text class="label">{{tRefundPhoneLabel}}</text>
      <input
        class="input"
        type="number"
        placeholder="{{tRefundPhonePlaceholder}}"
        value="{{applicantPhone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-wrapper">
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? tRefundSubmitting : tRefundSubmitBtn}}
    </button>
  </view>
</view>
