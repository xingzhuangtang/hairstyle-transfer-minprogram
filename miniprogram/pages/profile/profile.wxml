<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- 未登录提示 -->
  <view wx:if="{{!userInfo.id}}" class="not-logged-in-tip">
    <view class="tip-content">
      <text class="tip-icon">👤</text>
      <text class="tip-text">{{tProfileGuestMode}}</text>
    </view>
    <button class="login-btn" bindtap="goToLogin">{{tProfileLoginNow}}</button>
    <text class="tip-desc">{{tProfileLoginSync}}</text>
  </view>

  <!-- 已登录用户显示完整信息 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatar_url || '/images/icons/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="info">
          <view class="name-row">
            <text class="nickname">{{userInfo.nickname || tProfileNoNickname}}</text>
            <image wx:if="{{isPremium}}" class="vip-badge" src="/images/icons/vip.png"></image>
          </view>
          <view class="detail-row">
            <text class="user-id">ID: {{userInfo.device_id || tCommonUnknown}}</text>
          </view>
          <view class="detail-row">
            <text class="phone">{{userInfo.phone || tProfileNoPhone}}</text>
          </view>
        </view>
      </view>

      <!-- 会员信息 -->
      <view class="member-info">
        <view class="member-level {{isPremium ? 'premium' : 'normal'}}">
          <text class="level-text">{{memberLevelName}}</text>
        </view>
        <text wx:if="{{isPremium && daysRemaining > 0}}" class="expire-text">
          {{tProfileRemainingDays}}
        </text>
      </view>
    </view>

    <!-- 余额卡片 -->
    <view class="balance-card">
      <view class="balance-item">
        <text class="balance-value">{{userInfo.scissor_hairs || 0}}</text>
        <text class="balance-label">{{tProfileScissorHairs}}</text>
      </view>
      <view class="divider"></view>
      <view class="balance-item">
        <text class="balance-value">{{userInfo.comb_hairs || 0}}</text>
        <text class="balance-label">{{tProfileCombHairs}}</text>
      </view>
      <view class="divider"></view>
      <view class="balance-item">
        <text class="balance-value total">{{totalHairs}}</text>
        <text class="balance-label">{{tIndexTotal}}</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-list">
      <!-- 历史记录（会员专属） -->
      <view class="menu-item" bindtap="goToHistory">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/history.png"></image>
          <text class="menu-text">{{tProfileHistory}}</text>
          <text wx:if="{{!isPremium}}" class="vip-tag">VIP</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 消费记录 -->
      <view class="menu-item" bindtap="goToConsumption">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/consumption.png"></image>
          <text class="menu-text">{{tProfileConsumption}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 充值中心 -->
      <view class="menu-item" bindtap="goToBalance">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/recharge.png"></image>
          <text class="menu-text">{{tProfileRecharge}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 会员中心 -->
      <view class="menu-item" bindtap="goToMember">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/member.png"></image>
          <text class="menu-text">{{tProfileMemberCenter}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 在线客服 -->
      <view class="menu-item" bindtap="goToChat">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/chat.png"></image>
          <text class="menu-text">{{tProfileOnlineService}}</text>
          <text wx:if="{{chatUnreadCount > 0}}" class="unread-badge">{{chatUnreadCount > 99 ? '99+' : chatUnreadCount}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 客户留言 -->
      <view class="menu-item" bindtap="goToMessage">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/message.png"></image>
          <text class="menu-text">{{tProfileMessage}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 我的惊喜 -->
      <view class="menu-item" bindtap="goToReferral">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/referral.png"></image>
          <text class="menu-text">{{tProfileMySurprise}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 退款申请（仅管理员批准后显示） -->
      <view class="menu-item" bindtap="goToRefund" wx:if="{{refundEnabled}}">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/refund.png"></image>
          <text class="menu-text">{{tProfileRefundApply}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>

    <!-- 其他设置 -->
    <view class="menu-list settings">
      <!-- 设备管理 -->
      <view class="menu-item" bindtap="goToDevice">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/device.png"></image>
          <text class="menu-text">{{tProfileDeviceManage}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 关于我们 -->
      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/about.png"></image>
          <text class="menu-text">{{tProfileAboutUs}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>

      <!-- 设置 -->
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-left">
          <image class="menu-icon" src="/images/icons/settings.png"></image>
          <text class="menu-text">{{tCommonSettings}}</text>
        </view>
        <image class="arrow" src="/images/icons/arrow-right.png"></image>
      </view>
    </view>

    <!-- 开发者模式和测试工具（仅开发者可见） -->
    <view wx:if="{{isDeveloper}}">
      <!-- 留言管理 -->
      <view class="menu-list" style="margin-bottom: 30rpx;">
        <view class="menu-item" bindtap="goToMessageAdmin">
          <view class="menu-left">
            <image class="menu-icon" src="/images/icons/admin.png"></image>
            <text class="menu-text">{{tMessageAdminTitle}}</text>
          </view>
          <image class="arrow" src="/images/icons/arrow-right.png"></image>
        </view>
      </view>

      <view class="developer-section">
        <view class="developer-title">{{tProfileDeveloperMode}}</view>
        <view class="developer-card">
          <view class="developer-row">
            <text class="developer-label">{{tProfileDevStatus}}</text>
            <text class="developer-value {{isDeveloper ? 'on' : 'off'}}">{{tProfileDevOn}}</text>
          </view>
          <view class="developer-row">
            <text class="developer-label">{{tProfileDevMethod}}</text>
            <text class="developer-instructions">{{tProfileDevInstructions}}</text>
          </view>
          <button class="toggle-dev-mode-btn" bindtap="onViewDeveloperMode">
            {{tProfileViewDevMode}}
          </button>
        </view>
      </view>

      <!-- 测试工具（清除数据，模拟新客户） -->
      <view class="test-section">
        <view class="test-title">{{tProfileTestTools}}</view>
        <view class="test-card">
          <view class="test-row">
            <text class="test-label">{{tProfileCurrentAccount}}</text>
            <text class="test-value">{{userInfo.id ? 'QRQM' + userInfo.id + 'FXQY' : tCommonNotLoggedIn}}</text>
          </view>
          <view class="test-row">
            <text class="test-label">{{tProfileUserType}}</text>
            <text class="test-value">{{userInfo.user_type === 'guest' ? tCommonGuest : userInfo.user_type === 'registered' ? tProfileRegistered : userInfo.member_level === 'vip' ? tProfileVipMember : tCommonUnknown}}</text>
          </view>
          <button class="reset-test-btn" bindtap="onResetForTest" loading="{{resetLoading}}">
            {{tProfileClearData}}
          </button>
        </view>
      </view>
    </view>

    <!-- 开发者工具（仅开发者模式开启时显示） -->
    <view wx:if="{{isDeveloper}}" class="developer-section">
      <view class="developer-title">{{tProfileDeveloperTools}}</view>
      <view class="developer-card">
        <view class="developer-row">
          <text class="developer-label">{{tProfileCurrentVipStatus}}</text>
          <text class="developer-value">{{userInfo.member_level === 'vip' ? tProfileVipMember : tProfileNormalUser}}</text>
        </view>
        <view class="developer-row">
          <text class="developer-label">{{tProfileExpireTime}}</text>
          <text class="developer-value">{{userInfo.member_expire_at || tProfilePermanent}}</text>
        </view>
        <button class="toggle-vip-btn" bindtap="onToggleVip" loading="{{toggleLoading}}">
          {{userInfo.member_level === 'vip' ? tProfileSwitchToNormal : tProfileSwitchToVip}}
        </button>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-btn" bindtap="handleLogout">
      <text>{{tCommonLogout}}</text>
    </view>
  </block>
</view>
