/* pages/balance/balance.wxss */

.balance-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
}

.balance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.balance-value.total {
  font-size: 48rpx;
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 4rpx;
}

.balance-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 虚拟支付提示 */
.virtual-pay-notice {
  display: flex;
  align-items: center;
  background-color: #e8f4f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #1890ff;
  margin-bottom: 4rpx;
}

.notice-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
}

/* 充值区域 */
.recharge-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #ff6600;
  background-color: rgba(255, 102, 0, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.recharge-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.recharge-item {
  flex: 1;
  min-width: 300rpx;
  background-color: #f8f8f8;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.recharge-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
}

.recharge-item.active .amount,
.recharge-item.active .hairs-main,
.recharge-item.active .hairs-bonus {
  color: #ffffff;
}

.recommended {
  position: absolute;
  top: -2rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff9900, #ff6600);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx 0 12rpx 0;
}

.amount {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6600;
  margin-bottom: 16rpx;
}

.hairs-main {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.hairs-bonus {
  display: block;
  font-size: 24rpx;
  color: #52c41a;
}

/* 支付按钮 */
.pay-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  line-height: 96rpx;
  margin-bottom: 16rpx;
}

.pay-btn::after {
  border: none;
}

.pay-btn[disabled] {
  background: #cccccc;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 500;
}

.pay-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
}

/* 充值说明 */
.tips {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-dot {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
  line-height: 1.6;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
