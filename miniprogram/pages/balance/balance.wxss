/* pages/balance/balance.wxss */

.balance-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 30rpx;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 30rpx;
}

.balance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.balance-value.total {
  font-size: 48rpx;
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 充值区域 */
.recharge-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
}

/* 支付方式选择 */
.payment-method-section {
  margin-bottom: 40rpx;
}

.payment-method-list {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.payment-method-item {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  position: relative;
  transition: all 0.3s;
}

.payment-method-item.active {
  background-color: #f0f9ff;
  border-color: #1890ff;
}

.payment-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.payment-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.payment-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  transition: all 0.3s;
}

.payment-check.active {
  background-color: #1890ff;
  border-color: #1890ff;
  color: #ffffff;
}

/* 禁用状态的支付方式 */
.payment-method-item.disabled {
  background-color: #f0f0f0;
  opacity: 0.6;
  cursor: not-allowed;
}

.payment-method-item.disabled .payment-name {
  color: #999;
}

.coming-soon {
  font-size: 20rpx;
  color: #ff9900;
  background-color: rgba(255, 153, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: auto;
}

.recharge-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.recharge-item {
  flex: 1;
  min-width: 300rpx;
  background-color: #f8f8f8;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.recharge-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
}

.recharge-item.active .amount,
.recharge-item.active .hairs,
.recharge-item.active .bonus {
  color: #ffffff;
}

.recommended {
  position: absolute;
  top: -2rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff9900, #ff6600);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx 0 12rpx 0;
}

.amount {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;
  margin-bottom: 12rpx;
}

.hairs {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.bonus {
  display: block;
  font-size: 22rpx;
  color: #1aad19;
}

/* 支付按钮 */
.pay-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  line-height: 96rpx;
}

.pay-btn::after {
  border: none;
}

.pay-btn[disabled] {
  background: #cccccc;
}

/* 充值说明 */
.tips {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
