<!--pages/balance/balance.wxml-->
<view class="balance-container">
  <!-- 余额卡片 -->
  <view class="balance-card">
    <view class="balance-item">
      <text class="balance-value">{{scissorHairs}}</text>
      <text class="balance-label">剪刀发丝</text>
      <text class="balance-sub">购买获得</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value">{{combHairs}}</text>
      <text class="balance-label">梳子发丝</text>
      <text class="balance-sub">充值赠送</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value total">{{totalHairs}}</text>
      <text class="balance-label">总计</text>
    </view>
  </view>

  <!-- 虚拟支付提示 -->
  <view class="virtual-pay-notice">
    <view class="notice-icon">🔒</view>
    <view class="notice-content">
      <text class="notice-title">微信虚拟支付</text>
      <text class="notice-desc">本商品为虚拟商品，通过微信官方虚拟支付购买</text>
    </view>
  </view>

  <!-- 充值档位 -->
  <view class="recharge-section">
    <view class="section-header">
      <text class="section-title">选择充值档位</text>
      <text class="section-subtitle" wx:if="{{isVip}}">会员专享优惠</text>
    </view>

    <view class="recharge-list">
      <!-- 普通用户充值规则 -->
      <block wx:if="{{!isVip}}">
        <view
          class="recharge-item {{selectedAmount === 10 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="10">
          <text class="amount">¥10</text>
          <text class="hairs-main">1000 剪刀发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 20 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="20">
          <view class="recommended">推荐</view>
          <text class="amount">¥20</text>
          <text class="hairs-main">2000 剪刀发丝</text>
          <text class="hairs-bonus">+ 88 梳子发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 50 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="50">
          <text class="amount">¥50</text>
          <text class="hairs-main">5000 剪刀发丝</text>
          <text class="hairs-bonus">+ 588 梳子发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 100 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="100">
          <text class="amount">¥100</text>
          <text class="hairs-main">10000 剪刀发丝</text>
          <text class="hairs-bonus">+ 1688 梳子发丝</text>
        </view>
      </block>

      <!-- VIP会员充值规则 -->
      <block wx:else>
        <view
          class="recharge-item {{selectedAmount === 10 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="10">
          <text class="amount">¥10</text>
          <text class="hairs-main">1000 剪刀发丝</text>
          <text class="hairs-bonus">+ 8 梳子发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 20 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="20">
          <view class="recommended">推荐</view>
          <text class="amount">¥20</text>
          <text class="hairs-main">2000 剪刀发丝</text>
          <text class="hairs-bonus">+ 48 梳子发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 50 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="50">
          <text class="amount">¥50</text>
          <text class="hairs-main">5000 剪刀发丝</text>
          <text class="hairs-bonus">+ 299 梳子发丝</text>
        </view>

        <view
          class="recharge-item {{selectedAmount === 100 ? 'active' : ''}}"
          bindtap="selectAmount"
          data-amount="100">
          <text class="amount">¥100</text>
          <text class="hairs-main">10000 剪刀发丝</text>
          <text class="hairs-bonus">+ 888 梳子发丝</text>
        </view>
      </block>
    </view>

    <button class="pay-btn" bindtap="createOrder" disabled="{{!selectedAmount}}">
      <text class="btn-text">虚拟支付 {{selectedAmount ? '¥' + selectedAmount : ''}}</text>
    </button>
    <text class="pay-hint">通过微信官方虚拟支付完成购买</text>
  </view>

  <!-- 充值说明 -->
  <view class="tips">
    <text class="tip-title">充值说明</text>
    <view class="tip-list">
      <view class="tip-item">
        <text class="tip-dot">•</text>
        <text class="tip-text">剪刀发丝：充值购买获得，优先消费</text>
      </view>
      <view class="tip-item">
        <text class="tip-dot">•</text>
        <text class="tip-text">梳子发丝：充值额外赠送，剪刀发丝不足时消费</text>
      </view>
      <view class="tip-item">
        <text class="tip-dot">•</text>
        <text class="tip-text">充值后发丝立即到账</text>
      </view>
      <view class="tip-item">
        <text class="tip-dot">•</text>
        <text class="tip-text">如有疑问请联系客服</text>
      </view>
    </view>
  </view>
</view>
