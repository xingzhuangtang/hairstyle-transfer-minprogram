<!--pages/balance/balance.wxml-->
<view class="balance-container">
  <!-- 余额卡片 -->
  <view class="balance-card">
    <view class="balance-item">
      <text class="balance-value">{{scissorHairs}}</text>
      <text class="balance-label">剪刀发丝</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value">{{combHairs}}</text>
      <text class="balance-label">梳子发丝</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value total">{{totalHairs}}</text>
      <text class="balance-label">总计</text>
    </view>
  </view>

  <!-- 充值规则 -->
  <view class="recharge-section">
    <text class="section-title">选择充值金额</text>

    <!-- 支付方式选择 -->
    <view class="payment-method-section">
      <text class="section-title">选择支付方式</text>
      <view class="payment-method-list">
        <view
          class="payment-method-item {{paymentMethod === 'wechat' ? 'active' : ''}}"
          bindtap="selectPaymentMethod"
          data-method="wechat">
          <view class="payment-icon wechat">💚</view>
          <text class="payment-name">微信支付</text>
          <view class="payment-check {{paymentMethod === 'wechat' ? 'active' : ''}}">✓</view>
        </view>

        <view
          class="payment-method-item {{paymentMethod === 'alipay' ? 'active' : ''}}"
          bindtap="selectPaymentMethod"
          data-method="alipay">
          <view class="payment-icon alipay">💙</view>
          <text class="payment-name">支付宝</text>
          <view class="payment-check {{paymentMethod === 'alipay' ? 'active' : ''}}">✓</view>
        </view>
      </view>
    </view>

    <view class="recharge-list">
      <view
        class="recharge-item {{selectedAmount === 10 ? 'active' : ''}}"
        bindtap="selectAmount"
        data-amount="10">
        <text class="amount">¥10</text>
        <text class="hairs">1000发丝</text>
      </view>

      <view
        class="recharge-item {{selectedAmount === 20 ? 'active' : ''}}"
        bindtap="selectAmount"
        data-amount="20">
        <view class="recommended">推荐</view>
        <text class="amount">¥20</text>
        <text class="hairs">2088发丝</text>
        <text class="bonus">+赠送88梳子槽</text>
      </view>

      <view
        class="recharge-item {{selectedAmount === 50 ? 'active' : ''}}"
        bindtap="selectAmount"
        data-amount="50">
        <text class="amount">¥50</text>
        <text class="hairs">5588发丝</text>
        <text class="bonus">+赠送588梳子槽</text>
      </view>

      <view
        class="recharge-item {{selectedAmount === 100 ? 'active' : ''}}"
        bindtap="selectAmount"
        data-amount="100">
        <text class="amount">¥100</text>
        <text class="hairs">11688发丝</text>
        <text class="bonus">+赠送1688梳子槽</text>
      </view>
    </view>

    <button class="pay-btn" bindtap="createOrder" disabled="{{!selectedAmount || !paymentMethod}}">
      立即支付 {{selectedAmount ? '¥' + selectedAmount : ''}}
    </button>
  </view>

  <!-- 充值说明 -->
  <view class="tips">
    <text class="tip-title">充值说明：</text>
    <text class="tip-text">• 充值后发丝立即到账</text>
    <text class="tip-text">• 梳子槽发丝优先消费</text>
    <text class="tip-text">• 如有疑问请联系客服</text>
  </view>
</view>
