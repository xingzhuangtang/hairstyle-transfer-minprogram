<!--pages/balance/balance.wxml-->
<view class="balance-container">
  <!-- 余额卡片 -->
  <view class="balance-card">
    <view class="balance-item">
      <text class="balance-value">{{scissorHairs}}</text>
      <text class="balance-label">{{tBalanceScissorHairs}}</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value">{{combHairs}}</text>
      <text class="balance-label">{{tBalanceCombHairs}}</text>
    </view>
    <view class="divider"></view>
    <view class="balance-item">
      <text class="balance-value total">{{totalHairs}}</text>
      <text class="balance-label">{{tBalanceTotal}}</text>
    </view>
  </view>

  <!-- 充值规则 -->
  <view class="recharge-section">
    <text class="section-title">{{tBalanceSelectAmount}}</text>

    <!-- 支付方式选择 -->
    <view class="payment-method-section">
      <text class="section-title">{{tBalanceSelectPayment}}</text>
      <view class="payment-method-list">
        <view class="payment-method-item {{paymentMethod === 'wechat' ? 'active' : ''}}" bindtap="selectPaymentMethod" data-method="wechat">
          <view class="payment-icon wechat">💚</view>
          <text class="payment-name">{{tBalanceWechatPay}}</text>
          <view class="payment-check {{paymentMethod === 'wechat' ? 'active' : ''}}">✓</view>
        </view>

        <view class="payment-method-item disabled" catchtap="handleAlipayNotAvailable">
          <view class="payment-icon alipay">💙</view>
          <text class="payment-name">{{tBalanceAlipay}}</text>
          <text class="coming-soon">{{tCommonComingSoon}}</text>
        </view>
      </view>
    </view>

    <view class="recharge-list">
      <!-- 普通用户充值规则 -->
      <block wx:if="{{!isVip}}">
        <view class="recharge-item {{selectedAmount === 10 ? 'active' : ''}}" bindtap="selectAmount" data-amount="10">
          <text class="amount">¥10</text>
          <text class="hairs">{{tBalanceHairsNormal10}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 20 ? 'active' : ''}}" bindtap="selectAmount" data-amount="20">
          <view class="recommended">{{tBalanceRecommended}}</view>
          <text class="amount">¥20</text>
          <text class="hairs">{{tBalanceHairsNormal20}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 50 ? 'active' : ''}}" bindtap="selectAmount" data-amount="50">
          <text class="amount">¥50</text>
          <text class="hairs">{{tBalanceHairsNormal50}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 100 ? 'active' : ''}}" bindtap="selectAmount" data-amount="100">
          <text class="amount">¥100</text>
          <text class="hairs">{{tBalanceHairsNormal100}}</text>
        </view>
      </block>

      <!-- VIP会员充值规则 -->
      <block wx:else>
        <view class="recharge-item {{selectedAmount === 10 ? 'active' : ''}}" bindtap="selectAmount" data-amount="10">
          <text class="amount">¥10</text>
          <text class="hairs">{{tBalanceHairsVip10}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 20 ? 'active' : ''}}" bindtap="selectAmount" data-amount="20">
          <view class="recommended">{{tBalanceRecommended}}</view>
          <text class="amount">¥20</text>
          <text class="hairs">{{tBalanceHairsVip20}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 50 ? 'active' : ''}}" bindtap="selectAmount" data-amount="50">
          <text class="amount">¥50</text>
          <text class="hairs">{{tBalanceHairsVip50}}</text>
        </view>

        <view class="recharge-item {{selectedAmount === 100 ? 'active' : ''}}" bindtap="selectAmount" data-amount="100">
          <text class="amount">¥100</text>
          <text class="hairs">{{tBalanceHairsVip100}}</text>
        </view>
      </block>
    </view>

    <button class="pay-btn" bindtap="createOrder" disabled="{{!selectedAmount || !paymentMethod}}">
      {{tBalancePayNow}} {{selectedAmount ? '¥' + selectedAmount : ''}}
    </button>
  </view>

  <!-- 充值说明 -->
  <view class="tips">
    <text class="tip-title">{{tBalanceRechargeDesc}}</text>
    <text class="tip-text">{{tBalanceRechargeTip1}}</text>
    <text class="tip-text">{{tBalanceRechargeTip2}}</text>
    <text class="tip-text">{{tBalanceRechargeTip3}}</text>
  </view>
</view>
