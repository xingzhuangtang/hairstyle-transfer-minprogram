<!--pages/message/message.wxml-->
<view class="message-container">
  <view class="header">
    <text class="title">{{tMsgTitle}}</text>
    <text class="subtitle">{{tMsgSubtitle}}</text>
  </view>

  <view class="form-section">
    <!-- 姓名输入 -->
    <view class="form-item">
      <text class="label">{{tMsgName}} <text class="required">{{tMsgRequired}}</text></text>
      <input
        class="input"
        type="text"
        placeholder="{{tMsgNamePlaceholder}}"
        maxlength="20"
        value="{{name}}"
        bindinput="onNameInput"
      />
      <text class="char-count">{{name.length}}/20</text>
    </view>

    <!-- 电话输入 -->
    <view class="form-item">
      <text class="label">{{tMsgPhone}} <text class="required">{{tMsgRequired}}</text></text>
      <input
        class="input"
        type="number"
        placeholder="{{tMsgPhonePlaceholder}}"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <text class="char-count {{phone.length > 0 && phone.length !== 11 ? 'error' : ''}}">{{phone.length}}/11</text>
    </view>

    <!-- 留言内容 -->
    <view class="form-item">
      <text class="label">{{tMsgContent}} <text class="required">{{tMsgRequired}}</text></text>
      <textarea
        class="textarea"
        placeholder="{{tMsgContentPlaceholder}}"
        maxlength="500"
        value="{{content}}"
        bindinput="onContentInput"
        show-confirm-bar="{{false}}"
        auto-height
      />
      <text class="char-count {{content.length > 450 ? 'warning' : ''}}">{{content.length}}/500</text>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{(!name || !phone || !content || phone.length !== 11) ? 'disabled' : ''}}"
      bindtap="onSubmit"
      loading="{{submitting}}"
      disabled="{{!name || !phone || !content || phone.length !== 11 || submitting}}"
    >
      {{tMsgSubmit}}
    </button>
  </view>
</view>
